<apex:page controller="GrantApplicationPDFController" renderAs="pdf" showHeader="false" sidebar="false" standardStylesheets="false" applyBodyTag="false" applyHtmlTag="false">
    <html>
    <head>
        <style>
            @page {
                size: letter;
                margin: 15mm;
                @top-right {
                    content: "{!form.grantRecord.Reference_Number__c}";
                }
                @bottom-right {
                    content: "Page " counter(page) " of " counter(pages);
                }
                @top-center {
                    content: element(header);
                }
                @bottom-center {
                    content: element(footer);
                }
            }
            .page-break {
                display:block;
                page-break-after:always;
            }
            body {
                font-family: Arial Unicode MS;
                font-size:12px;
            }
            .tableBorder{            
                border-style: solid;
                border-color: #333333;
                border-collapse: collapse;
            }
            
            .tableBorder th {
                padding: 8px;
                border-style: solid;
                border-color: #333333;
            }
            
            .tableBorder td {
                padding: 8px;
                border-style: solid;
                border-color: #000000;
                background-color: #ffffff;
            }
        </style>
    </head>
    <body>
        <apex:form >
        <div class="">
            <table class="" width="100%">
                <tr >
                    <td width="100%" ><!--style="text-align:right;"-->
                        <img src="{!URLFOR($Resource.IA_Login_Logo)}" width="150px"/>
                    </td>
                </tr>
            </table>
        </div>
        <apex:variable var="sn" value="{!1}"/>
        <table style="width:100%; font-size:16px;">
            <tr>
                <td style="background-color:rgb(0,255,255);text-align:center"><b>{!form.grantRecord.RecordType.Name} Application Form</b></td>
            </tr>
        </table>
        <br/>
        <table style="border-collapse:collapse;width:100%" border="1" class="tableBorder">
            <tr >
                <td style="width:40%;padding-left:5px"><b>RESTRICTED:</b></td>
                <td style="padding-left:5px;width:60%"><b>COMMITTEE MEMBERS LEADING DISCUSSIONS:</b></td>
            </tr>
            <tr>
                <td style="padding-left:5px">
                    <apex:repeat value="{!form.restrictedReviewerList}" var="r">
                        {!r}<br/>
                    </apex:repeat>
                </td>
                <td style="padding-left:5px">
                    <apex:repeat value="{!form.cmldList}" var="r">
                        {!r}<br/>
                    </apex:repeat>
                </td>
            </tr>
        </table>
        <apex:outputPanel rendered="{!IF(form.isAdmin , true, false)}" layout="none">
        <br/>
        <table style="border-style:solid;border-color:black;border-width:1px 1px 1px 1px;width:100%">
            <tr >
                <td style="width:30%;padding-left:5px">{!form.grantRecord.Reference_Number__c}</td>
                <td style="width:40%">Grants Screening Committee Review</td> <!--{!form.grantsFundingName }-->
                <td style="width:30%">Meeting Date: 
                    <!--<apex:outputText value="{0, date, dd/MM/yyyy}">
                        <apex:param value="{!form.meetingDate}" /> 
                    </apex:outputText>-->
                </td>
            </tr>
            <apex:repeat value="{!form.investigatorRecordList}" var="inv">
                <apex:outputPanel rendered="{!IF(inv.code == 'PI', true, false)}" layout="none">
                <tr>
                    <td style="width:40%;padding-left:5px;text-align:start">Lead Principal Investigator</td>
                    <td colspan="2" style="width:60%;padding-left:5px"><b>{!inv.investigatorRecord.Full_Name__c}<br/>{!inv.investigatorRecord.Institution__r.Name}</b></td>
                </tr>
                </apex:outputPanel>
            </apex:repeat>
            <tr>
                <td style="width:40%;padding-left:5px;text-align:start">Amount Requested</td>
                <td colspan="2" style="width:60%;padding-left:5px">INR {!form.x10subTotal }</td>
            </tr>
            <tr>
                <td style="width:40%;padding-left:5px;text-align:start">Programme</td>
                <td colspan="2" style="width:60%;padding-left:5px"></td>
            </tr>
            <apex:repeat value="{!form.investigatorRecordList}" var="inv">
            <apex:outputPanel rendered="{!IF(inv.code != 'PI', true, false)}" layout="none">
            <tr>
                <td style="width:40%;padding-left:5px;text-align:start">Co-Principal Investigator</td>
                <td colspan="2" style="width:60%;padding-left:5px"><b>{!inv.investigatorRecord.Full_Name__c}<br/>{!inv.investigatorRecord.Institution__r.Name}</b></td>
            </tr>
            </apex:outputPanel>
            </apex:repeat>
            <tr>
                <td style="width:40%;padding-left:5px;text-align:start">Staff Member</td>
                <td colspan="2" style="width:60%;padding-left:5px"></td>
            </tr>
            <tr>
                <td style="width:40%;padding-left:5px;text-align:start">Comments</td>
                <td colspan="2" style="width:60%;padding-left:5px">{!form.comments }</td>
            </tr>
        </table>
        <br/>
        <table style="border-collapse:collapse;width:100%" border="1" class="tableBorder">
            <tr >
                <td style="width:33%;padding-left:5px"><b>Referee comments received</b></td>
                <td style="padding-left:5px;width:33%"><b>Referee willing- report not received</b></td>
                <td style="padding-left:5px;width:34%"><b>Referee unwilling/Not responded </b></td>
            </tr>
            <tr>
                <td style="padding-left:5px">
                    <!--<apex:repeat value="{!form.refereeCommentsReceivedList }" var="r">
                        {!r}<br/>
                    </apex:repeat>-->
                </td>
                <td style="padding-left:5px">
                    <apex:repeat value="{!form.reportnotReceivedList}" var="r">
                        {!r}<br/>
                    </apex:repeat>
                </td>
                <td style="padding-left:5px">
                    <apex:repeat value="{!form.notRespondedList }" var="r">
                        {!r}<br/>
                    </apex:repeat>
                </td>
            </tr>
        </table>
        <div style="page-break-after:always;"></div>
        </apex:outputPanel>
        <apex:outputPanel layout="none" rendered="{!form.isCRC}">
        <apex:variable var="sn" value="{!sn+1}"/>
        <center>
            <hr style="background-color:rgb(91, 155, 213);width:100%"/>
            <h4>
                <b><i style="font-size:14px;">1. Participating Institutions</i></b>
            </h4>
            <hr style="background-color:rgb(91, 155, 213);width:100%"/>
        </center>
        <br/><br/>
        <div class="QuestionClass">Q1. (a) If you are proposing a CRC with multiple institutions, please list them below: <br/><div></div></div><br/>
        <apex:repeat var="ins" value="{!form.institutionRecordList}">
            <table class="tableBorder" width="100%">
                <tbody>
                    <tr class="slds-line-height_reset">
                        <th class="" scope="col" colspan="2">
                            <div class=" " title="{! ins.Type__c}">{! ins.Type__c}
                            </div>
                        </th>
                    </tr>
                    <tr class="slds-line-height_reset">
                        <th class="" scope="col" width="30%">
                            <div class=" " title="">Full Name</div>
                        </th>
                        <th class="" scope="col" width="70%">
                            <div class=" " title="{! ins.Institution__r.Name }">{! ins.Institution__r.Name }<br/></div>
                        </th>
                    </tr>
                </tbody>
            </table>
            <br/>
        </apex:repeat>
        <br/><br/>
        <div class="slds-progress__item_content slds-grid slds-grid_align-spread QuestionClass">If a single institution is proposing this CRC, please provide a justification. In this case, please also list the departments that will participate in the programme.</div><br/>Justification (Limit 300 words)
        <br/>{!form.grantRecord.Institution_Justification__c}
        <div style="page-break-after:always;"></div>
        </apex:outputPanel>
        
        <center>
            <hr style="background-color:rgb(91, 155, 213);width:100%"/>
            <h4>
                <b><i style="font-size:14px;">{!sn}. Team composition and management</i></b>
                <apex:variable var="sn" value="{!sn+1}"/>
            </h4>
            <hr style="background-color:rgb(91, 155, 213);width:100%"/>
        </center>
        <br/>
        <i>Note: This section should include information on Lead PI and other PIs. If you want to add more investigators on the project, please add their information in the given format.</i>
        
        <br/><br/>
        <b>Q1.</b> Please provide composition of the team that is applying for this grant.
        <apex:variable var="index" value="{!1}"/>
        <apex:repeat value="{!form.investigatorRecordList}" var="inv">
            <br/>
            <table style="border: 1px solid black;border-collapse:collapse;width:100%">
                    <tr>
                        <td style="border: 1px solid black;padding-left:5px" colspan="2"><b>
                        <apex:outputPanel rendered="{!IF(inv.code == 'PI', true, false)}" layout="none">
                            {!index}. Lead Principal Investigator PI
                        </apex:outputPanel>
                        <apex:outputPanel rendered="{!IF(inv.code != 'PI', true, false)}" layout="none">
                            {!index}. Co - Principal Investigator {!inv.code}
                        </apex:outputPanel>
                        <apex:variable var="index" value="{!index+1}"/>
                        </b></td>
                    </tr>
                    <tr>
                        <td style="border: 1px solid black;padding-left:5px;width:50%">Full Name:</td>
                        <td style="border: 1px solid black;padding-left:5px">{!inv.investigatorRecord.Title__c} {!inv.investigatorRecord.Full_Name__c}</td>
                    </tr>
                    <tr>
                        <td style="border: 1px solid black;padding-left:5px">Discipline/expertise:</td>
                        <td style="border: 1px solid black;padding-left:5px">{!inv.investigatorRecord.Discipline_expertise__c}</td>
                    </tr>
                    <tr>
                        <td style="border: 1px solid black;padding-left:5px">Institution:<br/></td>
                        <td style="border: 1px solid black;padding-left:5px">{!inv.investigatorRecord.Institution__r.Name} <br/>{!inv.investigatorRecord.Institution__r.Department__c} <br/>{!inv.investigatorRecord.Institution__r.Address__c} {!inv.investigatorRecord.Institution__r.City__c} {!inv.investigatorRecord.Institution__r.Country__r.Name} {!inv.investigatorRecord.Institution__r.Pincode__c}</td>
                    </tr>
                    <tr>
                        <td style="border: 1px solid black;padding-left:5px">Role:</td>
                        <td style="border: 1px solid black;padding-left:5px">{!inv.investigatorRecord.Role__c}</td>
                    </tr>
                </table>
        </apex:repeat>
        <br/>
        <b>Q2.</b> Please describe why a team approach is necessary to execute this project. Define roles of all investigators and how the project will be managed and led. (Limit 500 words).
        <br/><br/>
        <div style="border: 1px solid black;padding-left:5px">
            <apex:outputText value="{!form.grantRecord.Describe_Why_Team_Approach_Is_necessary__c}" escape="false"/>
            <br/><br/><br/>
        </div>
        <br/><br/>
        <b>Q3. Time commitment</b>
            <br/>
                <i>Each PI should state time commitment towards following activities. If there are more PIs on the project, please add additional columns.</i>
            <table style="border: 1px solid black;border-collapse:collapse;width:100%" class="tableBorder">
               <tr class="slds-line-height_reset">
                    <th class="nowrap" scope="col" width="40%">
                        <div class=" " title="">Description</div>
                    </th>
                    <apex:repeat var="investigator" value="{!form.investigatorRecordList}">
                        <th class="" scope="col">
                            <div class=" " title="">{! investigator.investigatorRecord.Full_Name__c }<br/> {! investigator.code} </div>
                        </th>
                    </apex:repeat>
                </tr>
                <tr class="slds-line-height_reset">
                    <th class="nowrap" scope="col" width="40%">
                        <div class=" " title="">(A) Number of total working hours per week (B+C)</div>
                    </th>
                    <apex:repeat var="investigator" value="{!form.investigatorRecordList}">
                        <th class="" scope="col">
                            <div class=" " title="">{! investigator.investigatorRecord.Number_of_total_working_hours_per_week__c }</div>
                        </th>
                    </apex:repeat>
                </tr>
                <tr class="slds-line-height_reset">
                    <th class="nowrap" scope="col" width="40%">
                        <div class=" " title="">(B) Number of hours per week to be spent on non- <br/>research activities (E.g. teaching, administration, other institutional responsibilities)</div>
                    </th>
                    <apex:repeat var="investigator" value="{!form.investigatorRecordList}">
                        <th class="" scope="col">
                            <div class=" " title="">{! investigator.investigatorRecord.Hours_per_week_on_Non_Research_Activitiy__c }</div>
                        </th>
                    </apex:repeat>
                </tr>
                <tr class="slds-line-height_reset">
                    <th class="nowrap" scope="col" width="40%">
                        <div class=" " title="">(B) Number of hours per week to be spent on non- <br/>research activities (E.g. teaching, administration, other institutional responsibilities)</div>
                    </th>
                    <apex:repeat var="investigator" value="{!form.investigatorRecordList}">
                        <th class="" scope="col">
                            <div class=" " title="">{! investigator.investigatorRecord.Hours_per_week_on_Non_Research_Activitiy__c }</div>
                        </th>
                    </apex:repeat>
                </tr>
                <tr class="slds-line-height_reset">
                    <th class="nowrap" scope="col" width="40%">
                        <div class=" " title="">(C) Number of hours per week to be spent on research (D+E+F)</div>
                    </th>
                    <apex:repeat var="investigator" value="{!form.investigatorRecordList}">
                        <th class="" scope="col">
                            <div class=" " title="">{! investigator.investigatorRecord.Hours_per_week_to_be_spent_on_Research__c}</div>
                        </th>
                    </apex:repeat>
                </tr>
                <tr class="slds-line-height_reset">
                    <th class="nowrap" scope="col" width="40%">
                        <div class=" " title="">(D) Number of hours per week to be spent on <br/>active grants/fellowships/projects other than this proposed project</div>
                    </th>
                    <apex:repeat var="investigator" value="{!form.investigatorRecordList}">
                        <th class="" scope="col">
                            <div class=" " title="">{! investigator.investigatorRecord.Hours_per_week_on_Active_Grants_Projects__c}</div>
                        </th>
                    </apex:repeat>
                </tr>
                <tr class="slds-line-height_reset">
                    <th class="nowrap" scope="col" width="40%">
                        <div class=" " title="">(E) Number of hours per week to be spent on this project proposed to India Alliance.</div>
                    </th>
                    <apex:repeat var="investigator" value="{!form.investigatorRecordList}">
                        <th class="" scope="col">
                            <div class=" " title="">{! investigator.investigatorRecord.Hours_per_week_on_Project_Proposed_to_IA__c}</div>
                        </th>
                    </apex:repeat>
                </tr>
                <tr class="slds-line-height_reset">
                    <th class="nowrap" scope="col" width="40%">
                        <div class=" " title="">(F) If you are a practicing clinician, please indicate the number of hours <br/>per week to be spent in the clinic on the proposed project (do not include the clinic time in E)</div>
                    </th>
                    <apex:repeat var="investigator" value="{!form.investigatorRecordList}">
                        <th class="" scope="col">
                            <div class=" " title="">{! investigator.investigatorRecord.If_you_are_a_Practicing_Clinician__c}</div>
                        </th>
                    </apex:repeat>
                </tr>
            </table>
            <i>Note: For each PI, (a)=(b)+(c)+(d)+(e)+(f)</i>
            
            <apex:outputPanel layout="none" rendered="{!form.isCRC}">
            <div class="slds-col slds-size_1-of-1 slds-large-size_12-of-12 ">
                <br/><br/>
                <div class="slds-progress__item_content slds-grid slds-grid_align-spread QuestionClass">Q3.Clinical Research Training Programme (CRTP)</div>
                <div class="slds-progress__item_content slds-grid slds-grid_align-spread"><i>Note: CRTP is optional for the CRC. Please complete this section only if you also wish to apply for the CRTP. <br/>Note that CRTP would be embedded within CRC and is not open to individual applicants. This component will be over and above the budget requested for CRC.</i></div><br/>
                <div class="slds-progress__item_content slds-grid slds-grid_align-spread QuestionClass">(a)Please provide brief details of the participating institutions </div>
            </div>
            
            <div class="slds-col slds-size_1-of-1 slds-large-size_12-of-12">
                <br/><br/>
                <div class="slds-progress__item_content slds-grid slds-grid_align-spread">(*The lead institution is considered to be the administering organisation and in case of award, funds would only be transferred to it. This will be same as the PI’s Host Institution).</div>
                <div class="slds-progress__item_content slds-grid slds-grid_align-spread">Please provide details of designated programme head and coordinators.</div><br/>
            </div>
            <apex:variable var="index" value="{!1}"/>
        <apex:repeat value="{!form.investigatorRecordListPH}" var="inv">
            <br/>
            <table style="border: 1px solid black;border-collapse:collapse;width:100%">
                    <tr>
                        <td style="border: 1px solid black;padding-left:5px" colspan="2"><b>
                        {!index}. {! inv.investigatorRecord.Type__c}  &nbsp; {! inv.code}
                        <apex:variable var="index" value="{!index+1}"/>
                        </b></td>
                    </tr>
                    <tr>
                        <td style="border: 1px solid black;padding-left:5px;width:50%">Full Name:</td>
                        <td style="border: 1px solid black;padding-left:5px">{!inv.investigatorRecord.Title__c} {!inv.investigatorRecord.Full_Name__c}</td>
                    </tr>
                    <tr>
                        <td style="border: 1px solid black;padding-left:5px">Discipline/expertise:</td>
                        <td style="border: 1px solid black;padding-left:5px">{!inv.investigatorRecord.Discipline_expertise__c}</td>
                    </tr>
                    <tr>
                        <td style="border: 1px solid black;padding-left:5px">Institution:<br/></td>
                        <td style="border: 1px solid black;padding-left:5px">{!inv.investigatorRecord.Institution__r.Name} <br/>{!inv.investigatorRecord.Institution__r.Department__c} <br/>{!inv.investigatorRecord.Institution__r.Address__c} {!inv.investigatorRecord.Institution__r.City__c} {!inv.investigatorRecord.Institution__r.Country__r.Name} {!inv.investigatorRecord.Institution__r.Pincode__c}</td>
                    </tr>
                    <tr>
                        <td style="border: 1px solid black;padding-left:5px">Role:</td>
                        <td style="border: 1px solid black;padding-left:5px">{!inv.investigatorRecord.Role__c}</td>
                    </tr>
                </table>
        </apex:repeat>
        <br/>
        <b>Q2.</b> Please describe why a team approach is necessary to execute this project. Define roles of all investigators and how the project will be managed and led. (Limit 500 words).
        <br/><br/>
        <div style="border: 1px solid black;padding-left:5px">
            <apex:outputText value="{!form.grantRecord.Describe_Why_Team_Approach_Is_necessary__c}" escape="false"/>
            <br/><br/><br/>
        </div>
        <br/><br/>
        <div class="slds-progress__item_content slds-grid slds-grid_align-spread QuestionClass">(b) Time commitment</div>
        <div class="slds-progress__item_content slds-grid slds-grid_align-spread"><i>Programme head and coordinator should state their time commitment towards following activities. (If a PI/co-PI is also a programme head or coordinator then they should include their time commitment to this project in the previous section and need not duplicate it here). </i></div>
            <br/>
                <i>Each PI should state time commitment towards following activities. If there are more PIs on the project, please add additional columns.</i>
            <table style="border: 1px solid black;border-collapse:collapse;width:100%" class="tableBorder">
               <tr class="slds-line-height_reset">
                    <th class="nowrap" scope="col" width="40%">
                        <div class=" " title="">Description</div>
                    </th>
                    <apex:repeat var="investigator" value="{!form.investigatorRecordList}">
                        <th class="" scope="col">
                            <div class=" " title="">{! investigator.investigatorRecord.Full_Name__c }<br/> {! investigator.code} </div>
                        </th>
                    </apex:repeat>
                </tr>
                <tr class="slds-line-height_reset">
                    <th class="nowrap" scope="col" width="40%">
                        <div class=" " title="">(A) Number of total working hours per week (B+C)</div>
                    </th>
                    <apex:repeat var="investigator" value="{!form.investigatorRecordList}">
                        <th class="" scope="col">
                            <div class=" " title="">{! investigator.investigatorRecord.Number_of_total_working_hours_per_week__c }</div>
                        </th>
                    </apex:repeat>
                </tr>
                <tr class="slds-line-height_reset">
                    <th class="nowrap" scope="col" width="40%">
                        <div class=" " title="">(B) Number of hours per week to be spent on non- <br/>research activities (E.g. teaching, administration, other institutional responsibilities)</div>
                    </th>
                    <apex:repeat var="investigator" value="{!form.investigatorRecordList}">
                        <th class="" scope="col">
                            <div class=" " title="">{! investigator.investigatorRecord.Hours_per_week_on_Non_Research_Activitiy__c }</div>
                        </th>
                    </apex:repeat>
                </tr>
                <tr class="slds-line-height_reset">
                    <th class="nowrap" scope="col" width="40%">
                        <div class=" " title="">(B) Number of hours per week to be spent on non- <br/>research activities (E.g. teaching, administration, other institutional responsibilities)</div>
                    </th>
                    <apex:repeat var="investigator" value="{!form.investigatorRecordList}">
                        <th class="" scope="col">
                            <div class=" " title="">{! investigator.investigatorRecord.Hours_per_week_on_Non_Research_Activitiy__c }</div>
                        </th>
                    </apex:repeat>
                </tr>
                <tr class="slds-line-height_reset">
                    <th class="nowrap" scope="col" width="40%">
                        <div class=" " title="">(C) Number of hours per week to be spent on research (D+E+F)</div>
                    </th>
                    <apex:repeat var="investigator" value="{!form.investigatorRecordList}">
                        <th class="" scope="col">
                            <div class=" " title="">{! investigator.investigatorRecord.Hours_per_week_to_be_spent_on_Research__c}</div>
                        </th>
                    </apex:repeat>
                </tr>
                <tr class="slds-line-height_reset">
                    <th class="nowrap" scope="col" width="40%">
                        <div class=" " title="">(D) Number of hours per week to be spent on <br/>active grants/fellowships/projects other than this proposed project</div>
                    </th>
                    <apex:repeat var="investigator" value="{!form.investigatorRecordList}">
                        <th class="" scope="col">
                            <div class=" " title="">{! investigator.investigatorRecord.Hours_per_week_on_Active_Grants_Projects__c}</div>
                        </th>
                    </apex:repeat>
                </tr>
                <tr class="slds-line-height_reset">
                    <th class="nowrap" scope="col" width="40%">
                        <div class=" " title="">(E) Number of hours per week to be spent on this project proposed to India Alliance.</div>
                    </th>
                    <apex:repeat var="investigator" value="{!form.investigatorRecordList}">
                        <th class="" scope="col">
                            <div class=" " title="">{! investigator.investigatorRecord.Hours_per_week_on_Project_Proposed_to_IA__c}</div>
                        </th>
                    </apex:repeat>
                </tr>
                <tr class="slds-line-height_reset">
                    <th class="nowrap" scope="col" width="40%">
                        <div class=" " title="">(F) If you are a practicing clinician, please indicate the number of hours <br/>per week to be spent in the clinic on the proposed project (do not include the clinic time in E)</div>
                    </th>
                    <apex:repeat var="investigator" value="{!form.investigatorRecordList}">
                        <th class="" scope="col">
                            <div class=" " title="">{! investigator.investigatorRecord.If_you_are_a_Practicing_Clinician__c}</div>
                        </th>
                    </apex:repeat>
                </tr>
            </table>
            <i>Note: For each PI, (a)=(b)+(c)+(d)+(e)+(f)</i>
            </apex:outputPanel>
            <div style="page-break-before:always;"></div>
            
            <center>
                <hr style="background-color:rgb(91, 155, 213);width:100%"/>
                <h4>
                    <b><i>{!sn}. Team Science Grant Proposal</i></b>
                    <apex:variable var="sn" value="{!sn+1}"/>
                </h4>
                <hr style="background-color:rgb(91, 155, 213);width:100%"/>
