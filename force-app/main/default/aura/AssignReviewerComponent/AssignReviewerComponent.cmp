<aura:component controller ="AssignReviewerController" implements="force:appHostable,flexipage:availableForAllPageTypes,flexipage:availableForRecordHome,force:hasRecordId,forceCommunity:availableForAllPageTypes,force:lightningquickaction" access="global" >
    <aura:html tag="style">
        .slds-modal__container{
        height:unset !important;
        max-height:unset !important;
        max-width:unset !important;
        width: 85% !important;
        height: 95% !important;
        }
        .modal-body{
            height: 100% !important;
            max-height: 100% !important;
        }
    </aura:html>
    <aura:attribute name="addReview" type="boolean" default="false"/>
    <aura:attribute name="grant" type="object"/>
    <aura:handler name="init" value="{!this}" action="{!c.doInit}"/>
    
    <div class="{!v.addReview ? 'slds-show' : 'slds-hide'}">
        <section role="dialog" tabindex="-1" aria-labelledby="modal-heading-01" aria-modal="true" aria-describedby="modal-content-id-1" class="slds-modal slds-fade-in-open">
            <div class="slds-modal__container">
                <header class="slds-modal__header">
                    <h2 id="modal-heading-01" class="slds-modal__title slds-hyphenate">Add Reviewer</h2>
                </header>
                <div class="slds-modal__content slds-p-around_medium" id="modal-content-id-1">
                    <lightning:recordEditForm objectApiName="Assigned_Reviewer__c"
                                              onsuccess="{!c.handleCreateRecord}">
                        <lightning:messages />
                        <lightning:inputField aura:id="gId" fieldName="Grants__c" class="slds-hide"/>
                        <aura:if isTrue="{!v.addReview}"> 
                            <lightning:inputField fieldName="Assigned_User__c"/>
                            
                            <lightning:button name="v.addReview" class="slds-m-top_small" type="submit" label="Add Reviewer" />
                        </aura:if>
                    </lightning:recordEditForm>
                </div>
                <footer class="slds-modal__footer">
                    <lightning:button variant="neutral" label="Cancel" title="Cancel" name="v.addReview" onclick="{! c.closeModal }" />
                </footer>
            </div>
        </section>
        <div class="slds-backdrop slds-backdrop_open"></div>
    </div>
    <div style="text-align: end;">
    <lightning:button variant="brand" label="Add Reviewer" title="Add Reviewer" onclick="{! c.openModal }" />
        </div>
    <br/><br/>
    <table class="slds-table slds-table_cell-buffer slds-table_bordered">
        <thead>
            <tr class="slds-line-height_reset">
                <th class="" scope="col">
                    <div class="" title="Name">Name</div>
                </th>
                <th class="" scope="col" width="10%">
                    <div class=" " title="Action">Action</div>
                </th>
            </tr>
        </thead>
        <tbody>
            <aura:iteration var="cd" items="{!v.grant.Assigned_ReviewerList}" indexVar="indx">
                <tr class="slds-line-height_reset">
                    <th class="" scope="col">
                        {!cd.Assigned_User__r.Name}
                    </th>
                    <th class="" scope="col" width="10%">
                        <lightning:button variant="neutral" label="Remove" title="Remove" value="{!cd.Id}" onclick="{! c.removeRecord }" />
                    </th>
                </tr>
            </aura:iteration>
        </tbody>
    </table>
    <br/><br/>
</aura:component>