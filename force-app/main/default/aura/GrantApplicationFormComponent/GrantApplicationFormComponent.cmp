                                            <lightning:button variant="brand" label="Save &amp; Previous" title="Save &amp; Previous" value="8" onclick="{! c.save }" />
                                        </li>
                                        <li class="slds-button-group-item">
                                            <lightning:button variant="brand" label="Save &amp; Next" title="Save &amp; Next" value="10" onclick="{! c.save }" />
                                        </li>
                                        <li class="slds-button-group-item">
                                            <button class="slds-button slds-button_brand" onclick="{!c.saveAndRedirect}">Cancel</button>
                                        </li>
                                    </ul>
                                </aura:if>
                                <aura:if isTrue="{!v.defaultMode=='read'}">
                                    <ul class="slds-button-group-row">
                                        <li class="slds-button-group-item">
                                            <lightning:button variant="brand" label="Previous" title="Previous" value="8" onclick="{! c.next }" />
                                        </li>
                                        <li class="slds-button-group-item">
                                            <lightning:button variant="brand" label="Next" title="Next" value="10" onclick="{! c.next }" />
                                        </li>
