                                                        <div class=" " title="Action">Action</div>
                                                    </th>
                                                </aura:if>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <aura:iteration var="r" items="{!v.form.rarList}" indexVar="indx">
