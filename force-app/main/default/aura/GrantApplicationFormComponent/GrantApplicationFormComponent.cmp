                                    <br/><br/>
                                    <div class="QuestionClass">Q4. Will this work require approval from</div>
                                    <aura:if isTrue="{!v.defaultMode!='read'}">
                                        <ui:inputCheckbox label="Institutional Committee for Stem Cell Research (IC-SCR)" value="{!v.form.grantRecord.Institutional_Committee_for_Stem_Cell__c}"/>
