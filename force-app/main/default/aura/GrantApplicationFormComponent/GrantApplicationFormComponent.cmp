                                                                <th class="nowrap" scope="col">
                                                                    <div class=" ">
                                                                        <lightning:button variant="neutral" label="Edit" title="Edit" value="{! fo.Id}" name="v.showAddFO" onclick="{! c.editRecord }"/>
                                                                        <lightning:button variant="neutral" label="Remove" title="Remove" value="{!fo.Id}" onclick="{! c.removeRecord }" /></div>
                                                                </th>
                                                            </aura:if>
                                                        </tr>
                                                    </aura:iteration>
                                                </tbody>
