                                            <th class="" scope="col">
                                                <div class=" " title="Sub-total ">Sub-total </div>
                                            </th>
                                            <th class="" scope="col">
                                                <div class=" " title="{!v.form.subTotal }"><ui:outputCurrency value="{!v.form.subTotal }"/></div>
                                            </th>
                                        </tr>
                                        <tr class="slds-line-height_reset">
                                            <th class="" scope="col">
                                                <div class=" " title="(B)">(B)</div>
