                                                            <div class=" " title="Name of the funding organisation">Name of the funding organisation</div>
                                                        </th>
                                                        <th class="nowrap" scope="col">
                                                            <div class=" " title="Expected decision date">Expected decision date</div>
                                                        </th>  
                                                        <th class="nowrap" scope="col" style="width: 500px;">
                                                            <div class=" " title="Brief summary">Brief summary</div>
                                                        </th> 
                                                        <aura:if isTrue="{!v.defaultMode!='read'}">
                                                            <th class="nowrap" scope="col">
                                                                <div class=" " title="Action">Action </div>
                                                            </th>
                                                        </aura:if>
                                                    </tr>
                                                </thead>
                                                <tbody>
