                                </div>
                            </div>
                        </aura:iteration>
                        <div class="slds-col slds-size_1-of-1 slds-large-size_12-of-12" style="text-align: right;">
                            <aura:if isTrue="{!v.defaultMode!='read'}">
                                <br/>
                                <ul class="slds-button-group-row">
