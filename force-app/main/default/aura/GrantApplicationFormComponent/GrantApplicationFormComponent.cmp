                                    <ui:inputCheckbox label="Experiments with human stem cells " value="{!v.form.grantRecord.Experiments_with_human_stem_cells__c}"/>
                                    <ui:inputCheckbox label="Personal data" value="{!v.form.grantRecord.Personal_data__c}"/>
                                    <ui:inputCheckbox label="Biological samples" value="{!v.form.grantRecord.Biological_samples__c}"/>
                                </aura:if>
                                <aura:if isTrue="{!v.defaultMode=='read'}">
                                    <ui:inputCheckbox label="Human participants" value="{!v.form.grantRecord.Human_participants__c}" disabled="true"/>
                                    <ui:inputCheckbox label="Experiments with human stem cells " value="{!v.form.grantRecord.Experiments_with_human_stem_cells__c}" disabled="true"/>
                                    <ui:inputCheckbox label="Personal data" value="{!v.form.grantRecord.Personal_data__c}" disabled="true"/>
                                    <ui:inputCheckbox label="Biological samples" value="{!v.form.grantRecord.Biological_samples__c}" disabled="true"/>
                                </aura:if>
                                
                            </div>
                            <aura:if isTrue="{!or(v.form.grantRecord.Human_participants__c,v.form.grantRecord.Experiments_with_human_stem_cells__c)}">
