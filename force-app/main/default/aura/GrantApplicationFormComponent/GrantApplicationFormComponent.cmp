                                        <ui:inputCheckbox label="Institutional Ethics Committee (IEC) [According to ICMR guidelines, “IEC supplemented with additional expertise to review stem cell research may handle the proposals related to research on stem cells.]" value="{!v.form.grantRecord.Institutional_Ethics_Committee_IEC__c}" disabled="true"/>
