                                </table>
                                <br/>
                            </div>
                            <aura:if isTrue="{!v.form.isCRC}">
                                <div class="slds-col slds-size_1-of-1 slds-large-size_12-of-12 ">
                                    <br/><br/>
                                    <div class="slds-progress__item_content slds-grid slds-grid_align-spread QuestionClass">Q3.Clinical Research Training Programme (CRTP)</div>
                                    <div class="slds-progress__item_content slds-grid slds-grid_align-spread"><i>Note: CRTP is optional for the CRC. Please complete this section only if you also wish to apply for the CRTP. <br/>Note that CRTP would be embedded within CRC and is not open to individual applicants. This component will be over and above the budget requested for CRC.</i></div><br/>
                                    <div class="slds-progress__item_content slds-grid slds-grid_align-spread QuestionClass">(a)Please provide brief details of the participating institutions </div>
                                </div>
                                
                                <div class="slds-col slds-size_1-of-1 slds-large-size_12-of-12">
                                    <br/><br/>
                                    <div class="slds-progress__item_content slds-grid slds-grid_align-spread">(*The lead institution is considered to be the administering organisation and in case of award, funds would only be transferred to it. This will be same as the PI’s Host Institution).</div>
                                    <div class="slds-progress__item_content slds-grid slds-grid_align-spread">Please provide details of designated programme head and coordinators.</div><br/>
                                </div>
                                <div class="slds-col slds-size_1-of-1 slds-large-size_12-of-12">
                                    <aura:iteration var="investigator" items="{!v.form.investigatorRecordListPH}" indexVar="indx">
                                        <table class="slds-table slds-table_cell-buffer slds-table_bordered" width="100">
                                            <tbody>
                                                <tr class="slds-line-height_reset">
                                                    <th class="" scope="col" colspan="2">
                                                        <div class=" " title="{! investigator.investigatorRecord.Type__c}">{!indx +1}. {! investigator.investigatorRecord.Type__c}  &nbsp; {! investigator.code}
                                                            <aura:if isTrue="{!v.defaultMode!='read'}">
                                                                <div style="float: right;">
                                                                    <lightning:button variant="neutral" label="Edit" title="Edit" value="{! investigator.investigatorRecord.Id}" name="v.showAddInvestigatorPH" onclick="{! c.editRecord }"/>
                                                                    <lightning:button variant="neutral" label="Remove" title="Remove" value="{! investigator.investigatorRecord.Id}" onclick="{! c.removeRecord }" /></div>
                                                            </aura:if>
                                                        </div>
                                                    </th>
                                                </tr>
                                                <tr class="slds-line-height_reset">
                                                    <th class="" scope="col" width="30">
                                                        <div class=" " title="Principal Investigator">Full Name:</div>
                                                    </th>
                                                    <th class="" scope="col" width="70">
                                                        <div class=" " title="{! investigator.investigatorRecord.Full_Name__c }">{! investigator.investigatorRecord.Title__c }  {! investigator.investigatorRecord.Full_Name__c }<br/></div>
                                                    </th>
                                                </tr>
                                                
                                                <tr class="slds-line-height_reset">
                                                    <th class="" scope="col" width="30">
                                                        <div class=" " title="Discipline/expertise">Discipline/expertise:</div>
                                                    </th>
                                                    <th class="" scope="col" width="70">
                                                        <div class=" " title="">{! investigator.investigatorRecord.Discipline_expertise__c  }</div>
                                                    </th>
                                                </tr>
                                                <tr class="slds-line-height_reset">
                                                    <th class="" scope="col" width="30">
                                                        <div class=" " title="Institution">Institution:</div>
                                                    </th>
                                                    <th class="" scope="col" width="70">
                                                        <div class=" " title="">{! investigator.investigatorRecord.Institution__r.Name  }&nbsp; <br/>{! investigator.investigatorRecord.Institution__r.Department__c  }<br/>
                                                            {! investigator.investigatorRecord.Institution__r.Address__c  } <br/>
                                                            {! investigator.investigatorRecord.Institution__r.City__c}&nbsp; {! investigator.investigatorRecord.Institution__r.Country__r.Name}&nbsp; {! investigator.investigatorRecord.Institution__r.Pincode__c}
                                                        </div>
                                                    </th>
                                                </tr>
                                                <tr class="slds-line-height_reset">
                                                    <th class="" scope="col" width="30">
                                                        <div class=" " title="Role">Role:</div>
                                                    </th>
                                                    <th class="" scope="col" width="70">
                                                        <div class="" title="">{! investigator.investigatorRecord.Role__c }</div>
                                                    </th>
                                                </tr>
                                            </tbody>
                                        </table>
                                        <br/>
                                    </aura:iteration>
                                    <aura:if isTrue="{!v.defaultMode!='read'}"><lightning:button variant="brand" label="Add Programme Head/Coordinator" title="Add Programme Head/Coordinator " value="{! v.form.grantRecordId}" name="v.showAddInvestigatorPH" class="grantIdInvestigatorPH" onclick="{!c.openModal}" /></aura:if>
                                </div>
                                <div class="slds-col slds-size_1-of-1 slds-large-size_12-of-12">
                                    <br/><br/>
                                    <div class="slds-progress__item_content slds-grid slds-grid_align-spread QuestionClass">(b) Time commitment</div>
                                    <div class="slds-progress__item_content slds-grid slds-grid_align-spread"><i>Programme head and coordinator should state their time commitment towards following activities. (If a PI/co-PI is also a programme head or coordinator then they should include their time commitment to this project in the previous section and need not duplicate it here). </i></div>
                                </div>
                                <div class="slds-col slds-size_1-of-1 slds-large-size_12-of-12 tableScroll">
                                    
                                    <table class="slds-table slds-table_cell-buffer slds-table_bordered">
                                        <thead>
                                            
                                            <tr class="slds-line-height_reset">
                                                <th class="nowrap" scope="col" width="30">
                                                    <div class=" " title="">Description</div>
                                                </th>
                                                <aura:iteration var="investigator" items="{!v.form.investigatorRecordListPH}" indexVar="indx">
                                                    <th class="" scope="col">
                                                        <div class=" " title="">{! investigator.investigatorRecord.Full_Name__c }  &nbsp; {! investigator.code} </div>
                                                    </th>
                                                </aura:iteration>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <tr class="slds-line-height_reset">
                                                <th class="nowrap" scope="col" width="30">
                                                    <div class=" " title="Number of total working hours per week">(A) Number of total working hours per week (B+C)</div>
                                                </th>
                                                <aura:iteration var="investigator" items="{!v.form.investigatorRecordListPH}" indexVar="indx">
                                                    <th class="" scope="col">
                                                        <div class=" " title=""><lightning:input type="number" name="" step="0.01" value="{! investigator.investigatorRecord.Number_of_total_working_hours_per_week__c }" disabled="true"/></div>
                                                    </th>
                                                </aura:iteration>
                                            </tr>
                                            <tr class="slds-line-height_reset">
                                                <th class="nowrap" scope="col" width="30">
                                                    <div class=" " title="Number of hours per week to be spent on non- research activities (E.g. teaching, administration, other institutional responsibilities)">(B) Number of hours per week to be spent on non- <br/>research activities (E.g. teaching, administration, other institutional responsibilities)</div>
                                                </th>
                                                <aura:iteration var="investigator" items="{!v.form.investigatorRecordListPH}" indexVar="indx">
                                                    <th class="" scope="col">
                                                        <div class=" " title="">
                                                            <aura:if isTrue="{!v.defaultMode!='read'}">
                                                                <lightning:input type="number" name="" step="0.01" value="{! investigator.investigatorRecord.Hours_per_week_on_Non_Research_Activitiy__c }" onchange="{!c.handleTimeClick}"/>
                                                            </aura:if>
                                                            <aura:if isTrue="{!v.defaultMode=='read'}">
                                                                {! investigator.investigatorRecord.Hours_per_week_on_Non_Research_Activitiy__c }
                                                            </aura:if>
                                                        </div>
                                                    </th>
                                                </aura:iteration>
                                            </tr>
                                            <tr class="slds-line-height_reset">
                                                <th class="nowrap" scope="col" width="30">
                                                    <div class=" " title="Number of hours per week to be spent on research">(C) Number of hours per week to be spent on research (D+E+F)</div>
                                                </th>
                                                <aura:iteration var="investigator" items="{!v.form.investigatorRecordListPH}" indexVar="indx">
                                                    <th class="" scope="col">
                                                        <div class=" " title=""><lightning:input type="number" name="" step="0.01" value="{! investigator.investigatorRecord.Hours_per_week_to_be_spent_on_Research__c }" disabled="true"/></div>
                                                    </th>
                                                </aura:iteration>
                                            </tr>
                                            <tr class="slds-line-height_reset">
                                                <th class="nowrap" scope="col" width="30">
                                                    <div class=" " title="Number of hours per week to be spent on active grants/fellowships/projects other than this proposed project">(D) Number of hours per week to be spent on <br/>active grants/fellowships/projects other than this proposed project</div>
                                                </th>
                                                <aura:iteration var="investigator" items="{!v.form.investigatorRecordListPH}" indexVar="indx">
                                                    <th class="" scope="col">
                                                        <div class=" " title="">
                                                            <aura:if isTrue="{!v.defaultMode!='read'}">
                                                                <lightning:input type="number" name="" step="0.01" value="{! investigator.investigatorRecord.Hours_per_week_on_Active_Grants_Projects__c  }" onchange="{!c.handleTimeClick}"/>
                                                            </aura:if>
                                                            <aura:if isTrue="{!v.defaultMode=='read'}">
                                                                {! investigator.investigatorRecord.Hours_per_week_on_Active_Grants_Projects__c }
                                                            </aura:if>
                                                        </div>
                                                    </th>
                                                </aura:iteration>
                                            </tr>
                                            <tr class="slds-line-height_reset">
                                                <th class="nowrap" scope="col" width="30">
                                                    <div class=" " title="Number of hours per week to be spent on this project proposed to India Alliance. ">(E) Number of hours per week to be spent on this project proposed to India Alliance. </div>
                                                </th>
                                                <aura:iteration var="investigator" items="{!v.form.investigatorRecordListPH}" indexVar="indx">
                                                    <th class="" scope="col">
                                                        <div class=" " title="">
                                                            <aura:if isTrue="{!v.defaultMode!='read'}">
                                                                <lightning:input type="number" name="" step="0.01" value="{! investigator.investigatorRecord.Hours_per_week_on_Project_Proposed_to_IA__c  }" onchange="{!c.handleTimeClick}"/>
                                                            </aura:if>
                                                            <aura:if isTrue="{!v.defaultMode=='read'}">
                                                                {! investigator.investigatorRecord.Hours_per_week_on_Project_Proposed_to_IA__c }
                                                            </aura:if>
                                                        </div>
                                                    </th>
                                                </aura:iteration>
                                            </tr>
                                            <tr class="slds-line-height_reset">
                                                <th class="nowrap" scope="col" width="30">
                                                    <div class=" " title="If you are a practicing clinician, please indicate the number of hours per week to be spent in the clinic on the proposed project (do not include the clinic time in E)">(F) If you are a practicing clinician, please indicate the number of hours <br/>per week to be spent in the clinic on the proposed project (do not include the clinic time in E)</div>
                                                </th>
                                                <aura:iteration var="investigator" items="{!v.form.investigatorRecordListPH}" indexVar="indx">
                                                    <th class="" scope="col">
                                                        <div class=" " title="">
                                                            <aura:if isTrue="{!v.defaultMode!='read'}">
                                                                <lightning:input type="number" name=""  step="0.01" onchange="{!c.handleTimeClick}" value="{! investigator.investigatorRecord.If_you_are_a_Practicing_Clinician__c }"/>
                                                            </aura:if>
                                                            <aura:if isTrue="{!v.defaultMode=='read'}">
                                                                {! investigator.investigatorRecord.If_you_are_a_Practicing_Clinician__c }
                                                            </aura:if>
                                                        </div>
                                                    </th>
                                                </aura:iteration>
                                            </tr>
                                        </tbody>
                                    </table>
                                    <br/>
                                </div>
                            </aura:if>
                        </div>
                        <div class="slds-col slds-size_1-of-1 slds-large-size_12-of-12" style="text-align: right;">
                            <aura:if isTrue="{!v.defaultMode!='read'}">
                                <br/>
                                <ul class="slds-button-group-row">
                                    <li class="slds-button-group-item">
                                        <button class="slds-button slds-button_brand" onclick="{!c.save}">Save Draft</button>
                                    </li>
                                    <aura:if isTrue="{! v.form.isCRC}">
                                        <li class="slds-button-group-item">
                                            <lightning:button variant="brand" label="Save &amp; Previous" title="Save &amp; Previous" value="14" onclick="{! c.save }" />
                                        </li>
                                    </aura:if>
                                    <li class="slds-button-group-item">
                                        <lightning:button variant="brand" label="Save &amp; Next" title="Save &amp; Next" value="2" onclick="{! c.save }" />
                                    </li>
                                    <li class="slds-button-group-item">
                                        <button class="slds-button slds-button_brand" onclick="{!c.saveAndRedirect}">Cancel</button>
                                    </li>
                                </ul>
                            </aura:if>
                            <aura:if isTrue="{!v.defaultMode=='read'}">
                                <br/>
                                <ul class="slds-button-group-row">
                                    <aura:if isTrue="{! v.form.isCRC}">
                                        <li class="slds-button-group-item">
                                            <lightning:button variant="brand" label="Previous" title="Previous" value="14" onclick="{! c.next }" />
                                        </li>
                                    </aura:if>
                                    <li class="slds-button-group-item">
                                        <lightning:button variant="brand" label="Next" title="Next" value="2" onclick="{! c.next }" />
                                    </li>
                                </ul>
                            </aura:if>
                        </div>
                    </div>
                    <div class="{!v.currentStep == 'step2'? 'slds-show' : 'slds-hide'}">
                        <br/><br/>
                        <div class="slds-grid slds-wrap tab2">
                            <div class="slds-col slds-size_1-of-1 slds-large-size_8-of-12"> 
                                <div class="slds-page-header__name">
                                    <div class="slds-page-header__name-title">
                                        <h1>
                                            <span class="slds-page-header__title  " title="Team Science Grant Proposal">
                                                <aura:if isTrue="{! !v.form.isCRC}"><i>2. Team Science Grant Proposal</i></aura:if>
                                                <aura:if isTrue="{! v.form.isCRC}"><i>3. Proposed Clinical/Public Health Research Centre</i></aura:if>
                                            </span>
                                        </h1>
                                    </div>
                                </div>
                            </div>
                            <div class="slds-col slds-size_1-of-1 slds-large-size_4-of-12" style="text-align: right;">
                                <aura:if isTrue="{!v.defaultMode!='read'}">
                                    <ul class="slds-button-group-row">
                                        <li class="slds-button-group-item">
                                            <button class="slds-button slds-button_brand" onclick="{!c.save}">Save Draft</button>
                                        </li>
                                        <li class="slds-button-group-item">
                                            <lightning:button variant="brand" label="Save &amp; Previous" title="Save &amp; Previous" value="1" onclick="{! c.save }" />
                                        </li>
                                        <li class="slds-button-group-item">
                                            <lightning:button variant="brand" label="Save &amp; Next" title="Save &amp; Next" value="3" onclick="{! c.save }" />
                                        </li>
                                        <li class="slds-button-group-item">
                                            <button class="slds-button slds-button_brand" onclick="{!c.saveAndRedirect}">Cancel</button>
                                        </li>
                                    </ul>
                                </aura:if>
                                <aura:if isTrue="{!v.defaultMode=='read'}">
                                    <ul class="slds-button-group-row">
                                        <li class="slds-button-group-item">
                                            <lightning:button variant="brand" label="Previous" title="Previous" value="1" onclick="{! c.next }" />
                                        </li>
                                        <li class="slds-button-group-item">
                                            <lightning:button variant="brand" label="Next" title="Next" value="3" onclick="{! c.next }" />
                                        </li>
                                    </ul>
                                </aura:if>
                            </div>
                            <div class="slds-col slds-size_1-of-1 slds-large-size_12-of-12">
                                <br/><br/>
                                <div class="slds-progress__item_content slds-grid slds-grid_align-spread QuestionClass">Q1. Project Title (220 characters max.)</div><br/>
                            </div>
                            <div class="slds-col slds-size_1-of-1 slds-large-size_12-of-12">
                                <aura:if isTrue="{!v.defaultMode!='read'}">
                                    <lightning:input maxlength="220" name="" label="" value="{!v.form.grantRecord.Project_Title__c}"/>
                                </aura:if>
                                <aura:if isTrue="{!v.defaultMode=='read'}">
                                    {!v.form.grantRecord.Project_Title__c}
                                </aura:if>
                            </div>
                            <div class="slds-col slds-size_1-of-1 slds-large-size_12-of-12">
                                <br/>
                                <div class="slds-progress__item_content slds-grid slds-grid_align-spread QuestionClass">Q2. Duration of the grant (in months)</div><br/>
                            </div>
                            <div class="slds-col slds-size_1-of-1 slds-large-size_12-of-12">
                                <lightning:input maxlength="" name="" label="" value="{!v.form.grantRecord.Duration_of_the_grant_in_months__c}" disabled="true"/>
                            </div>
                            <div class="slds-col slds-size_1-of-1 slds-large-size_12-of-12">
                                <br/>
                                <div class="slds-progress__item_content slds-grid slds-grid_align-spread QuestionClass">Q3. Start date (DD/MM/YYYY)</div><br/>
                            </div>
                            <div class="slds-col slds-size_1-of-1 slds-large-size_12-of-12">
                                <aura:if isTrue="{!v.defaultMode!='read'}">
                                    <lightning:input type="date" maxlength="" min="{!v.startDateFrom}" name="" label="" value="{!v.form.grantRecord.Start_date__c}"/>
                                </aura:if>
                                <aura:if isTrue="{!v.defaultMode=='read'}">
                                    {!v.form.grantRecord.Start_date__c}
                                </aura:if>
                            </div>
                            <div class="slds-col slds-size_1-of-1 slds-large-size_12-of-12">
                                <div class="slds-progress__item_content slds-grid slds-grid_align-spread"><i>In case of an award, the PI would have to negotiate a start date with India Alliance. The details would be shared once the award is confirmed.  </i></div>
                            </div>
                            
                            <div class="slds-col slds-size_1-of-1 slds-large-size_12-of-12">
                                <br/>
                                <div class="slds-progress__item_content slds-grid slds-grid_align-spread QuestionClass">Q4. Project summary</div><br/>
                                <div class="slds-progress__item_content slds-grid slds-grid_align-spread"><i>Please provide a summary of the proposed research, including key goals, for an expert audience (Limit 200 words). Kindly be aware that India Alliance publishes the synopsis of the awarded grant on its own and on third party websites. </i></div>
                            </div>
                            <div class="slds-col slds-size_1-of-1 slds-large-size_12-of-12">
                                <aura:if isTrue="{!v.defaultMode!='read'}">
                                    <lightning:textarea class="200" name="" label="" value="{!v.form.grantRecord.Research_summary__c}" onchange="{!c.validateTextArea}"/>
                                </aura:if>
                                <aura:if isTrue="{!v.defaultMode=='read'}">
                                    {!v.form.grantRecord.Research_summary__c}
                                </aura:if>
                            </div>
                            <div class="slds-col slds-size_1-of-1 slds-large-size_12-of-12">
                                <br/>
                                <div class="slds-progress__item_content slds-grid slds-grid_align-spread QuestionClass">Q5. Lay summary</div><br/>
                                <div class="slds-progress__item_content slds-grid slds-grid_align-spread"><i>Please provide a summary of the proposed project, including key goals, for an expert audience (Limit 200 words). <br/>Kindly be aware that India Alliance publishes the synopsis of the awarded grant on its own and on third party websites.</i></div>
                            </div>
                            <div class="slds-col slds-size_1-of-1 slds-large-size_12-of-12">
                                <aura:if isTrue="{!v.defaultMode!='read'}">
                                    <lightning:textarea class="200" name="" label="" value="{!v.form.grantRecord.Lay_summary__c}" onchange="{!c.validateTextArea}"/>
                                </aura:if>
                                <aura:if isTrue="{!v.defaultMode=='read'}">
                                    {!v.form.grantRecord.Lay_summary__c}
                                </aura:if>
                            </div>
                            <div class="slds-col slds-size_1-of-1 slds-large-size_12-of-12">
                                <br/>
                                <div class="slds-progress__item_content slds-grid slds-grid_align-spread QuestionClass">Q6. Details of research project</div><br/>
                                <div class="slds-progress__item_content slds-grid slds-grid_align-spread"><i>Please provide full details of the proposal. These should include:</i></div>
                            </div>
                            <aura:if isTrue="{! !v.form.isCRC}">
                                <div class="slds-col slds-size_1-of-1 slds-large-size_12-of-12">
                                    <div class="slds-progress__item_content slds-grid slds-grid_align-spread"><i>a)	Background</i></div>
                                    <div class="slds-progress__item_content slds-grid slds-grid_align-spread"><i>b)	Aims and key questions</i></div>
                                    <div class="slds-progress__item_content slds-grid slds-grid_align-spread"><i>c)	Strategy and Work Plan</i></div>
                                    <div class="slds-progress__item_content slds-grid slds-grid_align-spread"><i>d)	Expected outcomes;</i></div>
                                    <div class="slds-progress__item_content slds-grid slds-grid_align-spread"><i>e)	Research management plan;</i></div>
                                    <div class="slds-progress__item_content slds-grid slds-grid_align-spread"><i>f)	Milestones (refer to the scheme guidelines) and sustainability plan;</i></div>
                                    <div class="slds-progress__item_content slds-grid slds-grid_align-spread"><i>g) A flowchart/organogram summarizing the requirement/role of each PI and Co-PIs on the project.</i></div>
                                    <div class="slds-progress__item_content slds-grid slds-grid_align-spread"><i>h)	Timelines: A Gantt chart showing key stages of the research plans, indicating the location and timelines. Since more than one organisation will be involved in the project, please specify the work that will be undertaken at each organisation. This chart should be placed just before the references. </i></div>
                                    <div class="slds-progress__item_content slds-grid slds-grid_align-spread"><i>i)	Full details of the study design for experiments (humans and animals) must be provided. This should include power calculations, sample size justification and, where appropriate, case definition and inclusion/exclusion criteria. The power calculation must be provided in a tabular format indicating the numbers under each group/sub-group that would be used for the project.</i></div>
                                    
                                </div>
                            </aura:if>
                            <aura:if isTrue="{! v.form.isCRC}">
                                <div class="slds-col slds-size_1-of-1 slds-large-size_12-of-12">
                                    <div class="slds-progress__item_content slds-grid slds-grid_align-spread"><i>a)	Background</i></div>
                                    <div class="slds-progress__item_content slds-grid slds-grid_align-spread"><i>b)	Aims and key questions</i></div>
                                    <div class="slds-progress__item_content slds-grid slds-grid_align-spread"><i>c) Existing research environment at the host institution(s)</i></div>
                                    <div class="slds-progress__item_content slds-grid slds-grid_align-spread"><i>d)	Strategy and Work Plan</i></div>
                                    <div class="slds-progress__item_content slds-grid slds-grid_align-spread"><i>e)	If you are applying for CRTP, please include</i></div>
                                    <div class="slds-progress__item_content slds-grid slds-grid_align-spread"><i>•	Number of fellowships that you wish to administer</i></div>
                                    <div class="slds-progress__item_content slds-grid slds-grid_align-spread"><i>•	Details of mentors/trainers involved</i></div>
                                    <div class="slds-progress__item_content slds-grid slds-grid_align-spread"><i>•	Selection process of candidates</i></div>
                                    <div class="slds-progress__item_content slds-grid slds-grid_align-spread"><i>f)	Availability and details of Clinical Study Design Unit (CSDU);</i></div>
                                    <div class="slds-progress__item_content slds-grid slds-grid_align-spread"><i>g)	Training and mentorship plan;</i></div>
                                    <div class="slds-progress__item_content slds-grid slds-grid_align-spread"><i>h)	Expected outcomes;</i></div>
                                    <div class="slds-progress__item_content slds-grid slds-grid_align-spread"><i>i)	Research management plan;</i></div>
                                    <div class="slds-progress__item_content slds-grid slds-grid_align-spread"><i>j)	Milestones (refer to the scheme guidelines) and sustainability plan;</i></div>
                                    <div class="slds-progress__item_content slds-grid slds-grid_align-spread"><i>k) A flowchart/organogram summarizing the requirement/role of each PI and Co-PIs on the project. </i></div>
                                    <div class="slds-progress__item_content slds-grid slds-grid_align-spread"><i>l) Timelines: A Gantt chart showing the research plans indicating the location and timelines. Since more than one organisation will be involved in the project, please specify the work that will be undertaken at each organisation. The Gantt chart may also represent the training periods of the CRTP fellows, if you are applying for the same. This Gantt chart should be placed just before the references.</i></div>
                                    <div class="slds-progress__item_content slds-grid slds-grid_align-spread"><i>m)	Full details of the study design for experiments (humans and animals) must be provided. This should include power calculations, sample size justification and, where appropriate, case definition and inclusion/exclusion criteria. The power calculation must be provided in a tabular format indicating the numbers under each group/sub-group that would be used for the project.</i></div>
                                    
                                </div>
                            </aura:if>
                            <div class="slds-col slds-size_1-of-1 slds-large-size_12-of-12">
                                <br/>
                                <div class="slds-progress__item_content slds-grid slds-grid_align-spread QuestionClass">Guidelines</div><br/>
                            </div>
                            <div class="slds-col slds-size_1-of-1 slds-large-size_12-of-12">
                                <div class="slds-progress__item_content slds-grid slds-grid_align-spread"><i>•	No more than 5,000 words should be used to describe the proposal, excluding graphs, figures, organogram, references etc.</i></div>
                                <div class="slds-progress__item_content slds-grid slds-grid_align-spread"><i>•	Your proposal should be written in 11-point Arial font, single space, and portrait format.</i></div>
                                <div class="slds-progress__item_content slds-grid slds-grid_align-spread"><i>•	Upto 3 pages of prelim data to explain what informed this study in form of graphs, figures and supporting unpublished information to be placed immediately after the proposal write-up References: Kindly provide full citation, including title of paper and all authors. “et al” to be used where there are more than 06 authors. Please use Vancouver referencing style. Please include an alphabetic listing of acronyms.</i></div>
                                <div class="slds-progress__item_content slds-grid slds-grid_align-spread"><i>•	In case your proposal is shortlisted for interview, you will be expected to present details of your advisory board to the Funding Committee.<br/> Funding for clinical trials is not permissible under this scheme.<br/> It should be in pdf format.</i> </div>
                            </div> 
                            <div class="slds-col slds-size_1-of-1 slds-large-size_12-of-12">  
                                
                                <!--<aura:if isTrue="{!v.defaultMode!='read'}">
                                    <lightning:textarea maxlength="" name="" label="" value="{!v.form.grantRecord.Proposal_Statements__c}"/>
                                </aura:if>
                                <aura:if isTrue="{!v.defaultMode=='read'}">
                                    {!v.form.grantRecord.Proposal_Statements__c}
                                </aura:if>-->
                                
                            </div>
                        </div>
                        <aura:if isTrue="{!v.currentStep == 'step2'}">
                            <aura:if isTrue="{!v.defaultMode!='read'}">
                                <lightning:fileUpload  name="fileUploader"
                                                      label= "Upload Documents"
                                                      multiple="false" 
                                                      recordId="{!v.form.grantRecord.Id}"
                                                      onuploadfinished="{! c.handleUploadFinished }"
                                                      disabled="{!not(empty(v.form.contentDocumentLinkList))}"/>
                            </aura:if>
                            <br/>
                            <table class="slds-table slds-table_cell-buffer slds-table_bordered">
                                <thead>
                                    <tr class="slds-line-height_reset">
                                        <th class="" scope="col">
                                            <div class="" title="File Name">File Name</div>
                                        </th>
                                        <aura:if isTrue="{!v.defaultMode!='read'}">
                                            <th class="" scope="col">
                                                <div class=" " title="Action">Action</div>
                                            </th>
                                        </aura:if>
                                    </tr>
                                </thead>
                                <tbody>
                                    <aura:iteration var="cd" items="{!v.form.contentDocumentLinkList}" indexVar="indx">
                                        <tr class="slds-line-height_reset">
                                            <th class="" scope="col">
                                                {!cd.ContentDocument.Title}
                                            </th>
                                            <aura:if isTrue="{!v.defaultMode!='read'}">
                                                <th class="" scope="col">
                                                    <lightning:button variant="neutral" label="Remove" title="Remove" value="{!cd.ContentDocumentId}" onclick="{! c.removeRecord }" />
                                                </th>
                                            </aura:if>
                                        </tr>
                                    </aura:iteration>
                                </tbody>
                            </table>
                            <br/><br/>
                        </aura:if>
                        <div class="slds-col slds-size_1-of-1 slds-large-size_12-of-12" style="text-align: right;">
                            <aura:if isTrue="{!v.defaultMode!='read'}">
                                <br/>
                                <ul class="slds-button-group-row">
                                    <li class="slds-button-group-item">
                                        <button class="slds-button slds-button_brand" onclick="{!c.save}">Save Draft</button>
                                    </li>
                                    <li class="slds-button-group-item">
                                        <lightning:button variant="brand" label="Save &amp; Previous" title="Save &amp; Previous" value="1" onclick="{! c.save }" />
                                    </li>
                                    <li class="slds-button-group-item">
                                        <lightning:button variant="brand" label="Save &amp; Next" title="Save &amp; Next" value="3" onclick="{! c.save }" />
                                    </li>
                                    <li class="slds-button-group-item">
                                        <button class="slds-button slds-button_brand" onclick="{!c.saveAndRedirect}">Cancel</button>
                                    </li>
                                </ul>
                            </aura:if>
                            <aura:if isTrue="{!v.defaultMode=='read'}">
                                <br/>
                                <ul class="slds-button-group-row">
                                    <li class="slds-button-group-item">
                                        <lightning:button variant="brand" label="Previous" title="Previous" value="1" onclick="{! c.next }" />
                                    </li>
                                    <li class="slds-button-group-item">
                                        <lightning:button variant="brand" label="Next" title="Next" value="3" onclick="{! c.next }" />
                                    </li>
                                </ul>
                            </aura:if>
                        </div>
                    </div>
                    
                    <div class="{!v.currentStep == 'step3'? 'slds-show' : 'slds-hide'}">
                        <br/><br/>
                        <div class="slds-grid slds-wrap tab2">
                            <div class="slds-col slds-size_1-of-1 slds-large-size_8-of-12"> 
                                <div class="slds-page-header__name">
                                    <div class="slds-page-header__name-title">
                                        <h1>
                                            <span class="slds-page-header__title  " title="Principal Investigator(s) CVs"><i>
                                                <aura:if isTrue="{! !v.form.isCRC}"><i>3. CVs of Investigators</i></aura:if>
                                                <aura:if isTrue="{! v.form.isCRC}"><i>4. CVs of Investigators</i></aura:if>
                                                </i></span>
                                        </h1>
                                    </div>
                                </div>
                                <div class="slds-progress__item_content slds-grid slds-grid_align-spread"><i>Note: This section should include information on PI and co-PIs. If you want to add more investigators on the project, please add their information in the given format.</i></div>
                            </div>
                            <div class="slds-col slds-size_1-of-1 slds-large-size_4-of-12" style="text-align: right;">
                                <aura:if isTrue="{!v.defaultMode!='read'}">
                                    <ul class="slds-button-group-row">
                                        <li class="slds-button-group-item">
                                            <button class="slds-button slds-button_brand" onclick="{!c.save}">Save Draft</button>
                                        </li>
                                        <li class="slds-button-group-item">
                                            <lightning:button variant="brand" label="Save &amp; Previous" title="Save &amp; Previous" value="2" onclick="{! c.save }" />
                                        </li>
                                        <li class="slds-button-group-item">
                                            <lightning:button variant="brand" label="Save &amp; Next" title="Save &amp; Next" value="4" onclick="{! c.save }" />
                                        </li>
                                        <li class="slds-button-group-item">
                                            <button class="slds-button slds-button_brand" onclick="{!c.saveAndRedirect}">Cancel</button>
                                        </li>
                                    </ul>
                                </aura:if>
                                <aura:if isTrue="{!v.defaultMode=='read'}">
                                    <ul class="slds-button-group-row">
                                        <li class="slds-button-group-item">
                                            <lightning:button variant="brand" label="Previous" title="Previous" value="2" onclick="{! c.next }" />
                                        </li>
                                        <li class="slds-button-group-item">
                                            <lightning:button variant="brand" label="Next" title="Next" value="4" onclick="{! c.next }" />
                                        </li>
                                    </ul>
                                </aura:if>
                            </div>
                        </div>
                        
                        <div class="slds-col slds-size_1-of-1 slds-large-size_12-of-12">
                            <br/>
                            <div class="slds-progress__item_content slds-grid slds-grid_align-spread QuestionClass">&nbsp;
                                <div>
                                    <aura:if isTrue="{!v.currentStep == 'step3'}">
                                        <lightning:select aura:id="selectInvestigator" name="select" value="{!v.form.selectedPI}" label="Select a Investigator" onchange="{! c.onChangeCV }">
                                            <aura:iteration var="investigator" items="{!v.form.investigatorRecordList}" indexVar="indx">
                                                <option value="{! investigator.investigatorRecord.Id }">{! investigator.investigatorRecord.Full_Name__c } &nbsp; {! investigator.code}</option>
                                            </aura:iteration>
                                            <aura:iteration var="investigator" items="{!v.form.investigatorRecordListPH}" indexVar="indx">
                                                <option value="{! investigator.investigatorRecord.Id }">{! investigator.investigatorRecord.Full_Name__c }  &nbsp; {! investigator.code}</option>
                                            </aura:iteration>
                                        </lightning:select> 
                                    </aura:if>
                                </div>
                            </div>
                        </div>
                        <aura:iteration var="investigator" items="{!v.form.investigatorRecordList}" indexVar="indx">
                            <div class="{!v.form.selectedPI == investigator.investigatorRecord.Id  ? 'slds-show' : 'slds-hide'}">
                                <div class="slds-progress__item_content slds-grid slds-grid_align-spread QuestionClass">Q1. Provide details and CVs of all Investigators (PIs, co-PIs)</div>
                                <div class="slds-col slds-size_1-of-1 slds-large-size_12-of-12">
                                    <table class="slds-table slds-table_cell-buffer slds-table_bordered">
                                        <tbody>
                                            
                                            <tr class="slds-line-height_reset">
                                                <th class="" scope="col" width="30">
                                                    <div class=" " title="">Role (Choose appropriately)</div>
                                                </th>
                                                <th class="" scope="col" width="70">
                                                    <div class=" " title="{!investigator.investigatorRecord.Role__c}">{!investigator.investigatorRecord.Role__c}</div>
                                                </th>
                                            </tr>
                                            <tr class="slds-line-height_reset">
                                                <th class="" scope="col" width="30">
                                                    <div class=" " title="Full Name ">Full Name</div>
                                                </th>
                                                <th class="" scope="col">
                                                    <div class=" " title="{!investigator.investigatorRecord.Full_Name__c}">{!investigator.investigatorRecord.Full_Name__c}</div>
                                                </th>
                                            </tr>
                                            <tr class="slds-line-height_reset">
                                                <th class="" scope="col" width="30">
                                                    <div class=" " title="Date of Birth (DD/MM/YYYY):">Date of Birth (DD/MM/YYYY)</div>
                                                </th>
                                                <th class="" scope="col">
                                                    <div class=" " title="{!investigator.investigatorRecord.Date_of_Birth__c}">{!investigator.investigatorRecord.Date_of_Birth__c}</div>
                                                </th>
                                            </tr>
                                            <tr class="slds-line-height_reset">
                                                <th class="" scope="col" width="30">
                                                    <div class=" " title="Nationality">Nationality</div>
                                                </th>
                                                <th class="" scope="col">
                                                    <div class=" " title="{!investigator.investigatorRecord.Nationality__c}">{!investigator.investigatorRecord.Nationality__c}</div>
                                                </th>
                                            </tr>
                                            <tr class="slds-line-height_reset">
                                                <th class="" scope="col" width="30">
                                                    <div class=" " title="Gender">Gender</div>
                                                </th>
                                                <th class="" scope="col">
                                                    <div class=" " title="{!investigator.investigatorRecord.Gender__c}">{!investigator.investigatorRecord.Gender__c}</div>
                                                </th>
                                            </tr>
                                            <tr class="slds-line-height_reset">
                                                <th class="" scope="col" width="30">
                                                    <div class=" " title="Direct contact number:(The office may contact you on this number). ">Direct contact number:<br/>(The office may contact you on this number). </div>
                                                </th>
                                                <th class="" scope="col">
                                                    <div class=" " title="{!investigator.investigatorRecord.Contact_Number__c}">{!investigator.investigatorRecord.Contact_Number__c}</div>
                                                </th>
                                            </tr>
                                            <tr class="slds-line-height_reset">
                                                <th class="" scope="col" width="30">
                                                    <div class=" " title="Email ID">Email ID</div>
                                                </th>
                                                <th class="" scope="col">
                                                    <div class=" " title="{!investigator.investigatorRecord.Email__c}">{!investigator.investigatorRecord.Email__c}</div>
                                                </th>
                                            </tr>
                                            <tr class="slds-line-height_reset">
                                                <th class="" scope="col" width="30">
                                                    <div class=" " title="Expertise">Expertise</div>
                                                </th>
                                                <th class="" scope="col">
                                                    <div class=" " title="{!investigator.investigatorRecord.Discipline_expertise__c}">{!investigator.investigatorRecord.Discipline_expertise__c}</div>
                                                </th>
                                            </tr>
                                            <tr class="slds-line-height_reset">
                                                <th class="" scope="col" width="30">
                                                    <div class=" " title="ORCID ID">ORCID ID </div>
                                                </th>
                                                <th class="" scope="col">
                                                    <div class=" " title="{!investigator.investigatorRecord.ORCID_ID__c}">{!investigator.investigatorRecord.ORCID_ID__c}</div>
                                                </th>
                                            </tr>
                                        </tbody>
                                    </table>
                                    <br/>
                                </div>
                                <div class="slds-col slds-size_1-of-1 slds-large-size_12-of-12">
                                    <br/>
                                    <div class="slds-progress__item_content slds-grid slds-grid_align-spread QuestionClass">Q2. Current position</div>
                                </div>
                                <div class="slds-col slds-size_1-of-1 slds-large-size_12-of-12 tableScroll">
                                    
                                    <table class="slds-table slds-table_cell-buffer slds-table_bordered">
                                        <tbody>
                                            <tr class="slds-line-height_reset">
                                                <th class="nowrap" scope="col" width="30">
                                                    <div class=" " title="Name of the institution">Name of the institution</div>
                                                </th>
                                                <th class="" scope="col">
                                                    <div class=" " title="{!investigator.investigatorRecord.Institution__r.Name}">{!investigator.investigatorRecord.Institution__r.Name}</div>
                                                </th>
                                            </tr>
                                            <tr class="slds-line-height_reset">
                                                <th class="nowrap" scope="col" width="30">
                                                    <div class=" " title="Name of the Sponsor ">Name of the Sponsor <br/><i>Check Sponsor and Sponsoring Institutes <a href="https://www.indiaalliance.org/team-science-grants" target="_blank">here</a></i></div>
                                                </th>
                                                <th class="" scope="col">
                                                    <aura:if isTrue="{!v.defaultMode!='read'}">
                                                        <lightning:input maxlength="" name="" label="" value="{!investigator.investigatorRecord.Name_of_the_Sponsor__c}"/>
                                                    </aura:if>
                                                    <aura:if isTrue="{!v.defaultMode=='read'}">
                                                        {!investigator.investigatorRecord.Name_of_the_Sponsor__c}
                                                    </aura:if>
                                                </th>
                                            </tr>
                                            <tr class="slds-line-height_reset">
                                                <th class="nowrap" scope="col" width="30">
                                                    <div class=" " title="Email of the Sponsor">Email of the Sponsor</div>
                                                </th>
                                                <th class="" scope="col">
                                                    <aura:if isTrue="{!v.defaultMode!='read'}">
                                                        <lightning:input maxlength="" name="" label="" value="{!investigator.investigatorRecord.Email_of_the_Sponsor__c}"/>
                                                    </aura:if>
                                                    <aura:if isTrue="{!v.defaultMode=='read'}">
                                                        {!investigator.investigatorRecord.Email_of_the_Sponsor__c}
                                                    </aura:if>
                                                </th>
                                            </tr>
                                            <tr class="slds-line-height_reset">
                                                <th class="" scope="col" width="30">
                                                    <div class="nowrap" title="(a) Title of current post ">(a) Title of current post</div>
                                                </th>
                                                <th class="" scope="col">
                                                    <aura:if isTrue="{!v.defaultMode!='read'}">
                                                        <lightning:input  maxlength="" name="" label="" value="{!investigator.investigatorRecord.Title_of_current_Post__c}"/>
                                                    </aura:if>
                                                    <aura:if isTrue="{!v.defaultMode=='read'}">
                                                        {!investigator.investigatorRecord.Title_of_current_Post__c}
                                                    </aura:if>
                                                </th>
                                            </tr> 
                                            <tr>
                                                <th class="" scope="col" colspan="2">
                                                    <div class="nowrap" title="(b) With whom do you have your contract of employment? ">(b) With whom do you have your contract of employment? </div>
                                                    <aura:if isTrue="{!v.defaultMode!='read'}">
                                                        <lightning:textarea maxlength="" name="" label="" value="{!investigator.investigatorRecord.Your_Contract_of_Employment__c}"/>
                                                    </aura:if>
                                                    <aura:if isTrue="{!v.defaultMode=='read'}">
                                                        {!investigator.investigatorRecord.Your_Contract_of_Employment__c}
                                                    </aura:if>
                                                </th>
                                            </tr>
                                            <tr>
                                                <th class="" scope="col" colspan="2">
                                                    <div class="nowrap" title="(c) Source of personal salary support">(c) Source of personal salary support<br/><i><br/>Also be specific if your current salary is funded from more than one source. Indicate with an asterisk (*) those sources of salary support that have contributed to the background of this proposal. </i></div>
                                                    <aura:if isTrue="{!v.defaultMode!='read'}">
                                                        <lightning:textarea maxlength="" name="" label="" value="{!investigator.investigatorRecord.Source_of_personal_salary_support__c}"/>
                                                    </aura:if>
                                                    <aura:if isTrue="{!v.defaultMode=='read'}">
                                                        {!investigator.investigatorRecord.Source_of_personal_salary_support__c}
                                                    </aura:if>
                                                </th>
                                            </tr> 
                                            <tr>
                                                <th class="" scope="col" colspan="2">
                                                    <div class="nowrap" title="(d) Other affiliations in any other organization">(d) Other affiliations in any other organization</div>
                                                    <aura:if isTrue="{!v.defaultMode!='read'}">
                                                        <lightning:textarea maxlength="" name="" label="" value="{!investigator.investigatorRecord.Other_affiliations__c}"/>
                                                    </aura:if>
                                                    <aura:if isTrue="{!v.defaultMode=='read'}">
                                                        {!investigator.investigatorRecord.Other_affiliations__c}
                                                    </aura:if>
                                                </th>
                                            </tr> 
                                        </tbody>
                                    </table>  
                                    <br/>
                                </div>
                                <div class="slds-col slds-size_1-of-1 slds-large-size_12-of-12">
                                    <br/>
                                    <div class="slds-progress__item_content slds-grid slds-grid_align-spread QuestionClass">Q3. Highest Degree (PhD/MD/MBBS-MS/MD-PhD/MPH/equivalent)</div>
                                </div>
                                <div class="slds-col slds-size_1-of-1 slds-large-size_12-of-12">
                                    <aura:if isTrue="{!v.defaultMode!='read'}">
                                        <lightning:input maxlength="" name="" label="" value="{!investigator.investigatorRecord.Highest_Degree__c}"/>
                                    </aura:if>
                                    <aura:if isTrue="{!v.defaultMode=='read'}">
                                        {!investigator.investigatorRecord.Highest_Degree__c}
                                    </aura:if>
                                    
                                </div>
                                <div class="slds-col slds-size_1-of-1 slds-large-size_12-of-12">
                                    <br/>
                                    <div class="slds-progress__item_content slds-grid slds-grid_align-spread QuestionClass">Q4. For how many years have you been running an independent research group or lab?<i>Please exclude your non-research career break, if any.</i></div>
                                </div>
                                <div class="slds-col slds-size_1-of-1 slds-large-size_12-of-12">
                                    <aura:if isTrue="{!v.defaultMode!='read'}">
                                        <lightning:input type="number" label="" value="{!investigator.investigatorRecord.Years_of_Running_Research_Group_Lab__c}" step="0.01"/>
                                        <!--<lightning:input maxlength="" name="" label="" value="{!investigator.investigatorRecord.Years_of_Running_Research_Group_Lab__c}"/>-->
                                    </aura:if>
                                    <aura:if isTrue="{!v.defaultMode=='read'}">
                                        {!investigator.investigatorRecord.Years_of_Running_Research_Group_Lab__c}
                                    </aura:if>
                                </div>
                                <div class="slds-col slds-size_1-of-1 slds-large-size_12-of-12">
                                    <br/>
                                    <div class="slds-progress__item_content slds-grid slds-grid_align-spread QuestionClass">Q5. Previous posts held (list the most recent first)<aura:if isTrue="{!v.defaultMode!='read'}"><div style="text-align:right;"><lightning:button variant="neutral" value="{! investigator.investigatorRecord.Id}" name="v.showAddPost" class="InvId" label="Add Post" title="Add Post" onclick="{! c.openModal }" /></div></aura:if></div>
                                </div>
                                <div class="slds-col slds-size_1-of-1 slds-large-size_12-of-12">
                                    <br/>
                                    <table class="slds-table slds-table_cell-buffer slds-table_bordered">
                                        <thead>
                                            <tr class="slds-line-height_reset">
                                                <th class="" scope="col">
                                                    <div class=" " title="Date from (mm/yyyy) ">Date from (yyyy/mm/dd)</div>
                                                </th>
                                                <th class="" scope="col">
                                                    <div class=" " title="Date to (mm/yyyy) ">Date to (yyyy/mm/dd)</div>
                                                </th>
                                                <th class="" scope="col">
                                                    <div class=" " title="Position">Position</div>
                                                </th>
                                                <th class="" scope="col">
                                                    <div class=" " title="Department">Department</div>
                                                </th>
                                                <th class="" scope="col">
                                                    <div class=" " title="Organisation">Institution/University</div>
                                                </th>
                                                <th class="" scope="col">
                                                    <div class=" " title="Supervisor">Supervisor</div>
                                                </th>
                                                <aura:if isTrue="{!v.defaultMode!='read'}">
                                                    <th class="" scope="col">
                                                        <div class=" " title="Action">Action</div>
                                                    </th>
                                                </aura:if>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <aura:iteration var="ph" items="{!investigator.phList}">
                                                <tr class="slds-line-height_reset">
                                                    <th class="" scope="col">
                                                        <div class=" " title="{!ph.Date_From__c}">{!ph.Date_From__c}</div>
                                                    </th>
                                                    <th class="" scope="col">
                                                        <div class=" " title="{!ph.Date_To__c}">{!ph.Date_To__c}</div>
                                                    </th>
                                                    <th class="" scope="col">
                                                        <div class=" " title="{!ph.Name }">{!ph.Position__c }</div>
                                                    </th>
                                                    <th class="" scope="col">
                                                        <div class=" " title="{!ph.Department__c}">{!ph.Department__c}</div>
                                                    </th>
                                                    <th class="" scope="col">
                                                        <div class=" " title="{!ph.Organisations__r.Name}">{!ph.Organisations__r.Name} </div>
                                                    </th>
                                                    <th class="" scope="col">
                                                        <div class=" " title="{!ph.Supervisor__c}">{!ph.Supervisor__c}</div>
                                                    </th>
                                                    <aura:if isTrue="{!v.defaultMode!='read'}">
                                                        <th>
                                                            <lightning:button variant="neutral" label="Edit" title="Edit" value="{! ph.Id}" name="v.showAddPost" onclick="{! c.editRecord }"/>
                                                            <lightning:button variant="neutral" value="{! ph.Id}" label="Remove" title="Remove" onclick="{! c.removeRecord }" />
                                                        </th>
                                                    </aura:if>
                                                </tr>
                                            </aura:iteration>
                                        </tbody>
                                    </table>
                                </div> 
                                <div class="slds-col slds-size_1-of-1 slds-large-size_12-of-12">
                                    <br/>
                                    <div class="slds-progress__item_content slds-grid slds-grid_align-spread QuestionClass">Q6. Education/training (list the most recent first)<aura:if isTrue="{!v.defaultMode!='read'}"><div style="text-align:right;"><lightning:button variant="neutral" value="{! investigator.investigatorRecord.Id}" label="Add Education/Training" name="v.showAddEducation" class="InvIdEdu" title="Add Education/Training" onclick="{! c.openModal }" /></div></aura:if></div>
                                </div>
                                <div class="slds-col slds-size_1-of-1 slds-large-size_12-of-12">
                                    <br/>
                                    <table class="slds-table slds-table_cell-buffer slds-table_bordered">
                                        <thead>
                                            <tr class="slds-line-height_reset">
                                                <th class="" scope="col"> 
                                                    <div class=" " title="Date from (mm/yyyy) ">Date from (yyyy/mm/dd)</div>
                                                </th>
                                                <th class="" scope="col">
                                                    <div class=" " title="Date to (mm/yyyy) ">Date to (yyyy/mm/dd)</div>
                                                </th>
                                                <th class="" scope="col">
                                                    <div class=" " title="Qualification">Qualification</div>
                                                </th>
                                                <th class="" scope="col">
                                                    <div class=" " title="Subject">Subject</div>
                                                </th>
                                                <th class="" scope="col">
                                                    <div class=" " title="Organisation">Institution/University</div>
                                                </th>
                                                <th class="" scope="col">
                                                    <div class=" " title="Supervisor">Supervisor</div>
                                                </th>
                                                <aura:if isTrue="{!v.defaultMode!='read'}">
                                                    <th class="" scope="col">
                                                        <div class=" " title="Action">Action</div>
                                                    </th>
                                                </aura:if>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <aura:iteration var="quly" items="{!investigator.qualificationlList}">
                                                <tr class="slds-line-height_reset">
                                                    <th class="" scope="col">
                                                        <div class=" " title="{!quly.Date_From__c}">{!quly.Date_From__c}</div>
                                                    </th>
                                                    <th class="" scope="col">
                                                        <div class=" " title="{!quly.Date_To__c}">{!quly.Date_To__c}</div>
                                                    </th>
                                                    <th class="" scope="col">
                                                        <div class=" " title="{!quly.Name}">{!quly.Qualification__c}</div>
                                                    </th>
                                                    <th class="" scope="col">
                                                        <div class=" " title="{!quly.Subject__c}">{!quly.Subject__c}</div>
                                                    </th>
                                                    <th class="" scope="col">
                                                        <div class=" " title="{!quly.Organisation__r.Name}">{!quly.Organisation__r.Name}</div>
                                                    </th>
                                                    <th class="" scope="col">
                                                        <div class=" " title="{!quly.Supervisor__c}">{!quly.Supervisor__c}</div>
                                                    </th>
                                                    <aura:if isTrue="{!v.defaultMode!='read'}">
                                                        <th>
                                                            <lightning:button variant="neutral" label="Edit" title="Edit" value="{! quly.Id}" name="v.showAddEducation" onclick="{! c.editRecord }"/>
                                                            <lightning:button variant="neutral" value="{! quly.Id}" label="Remove" title="Remove" onclick="{! c.removeRecord }" />
                                                        </th>
                                                    </aura:if>
                                                </tr>
                                            </aura:iteration>
                                        </tbody>
                                    </table>
                                </div>
                                
                                <div class="slds-col slds-size_1-of-1 slds-large-size_12-of-12">
                                    <br/>
                                    <div class="slds-progress__item_content slds-grid slds-grid_align-spread QuestionClass">Q7. Summary of scientific career to date, including key achievements (Limit 350 words)</div>
                                </div>
                                <div class="slds-col slds-size_1-of-1 slds-large-size_12-of-12">
                                    <aura:if isTrue="{!v.defaultMode!='read'}">
                                        <lightning:textarea class="350" name="" label="" value="{!investigator.investigatorRecord.Summary_of_Scientific_Career_to_Date__c}" onchange="{!c.validateTextArea}"/>
                                    </aura:if>
                                    <aura:if isTrue="{!v.defaultMode=='read'}">
                                        {!investigator.investigatorRecord.Summary_of_Scientific_Career_to_Date__c}
                                    </aura:if>
                                </div>
                                <div class="slds-col slds-size_1-of-1 slds-large-size_12-of-12">
                                    <br/>
                                    <div class="slds-progress__item_content slds-grid slds-grid_align-spread QuestionClass">Q8. Experience relevant to this proposal (Limit 350 words)</div>
                                </div>
                                <div class="slds-col slds-size_1-of-1 slds-large-size_12-of-12">
                                    <aura:if isTrue="{!v.defaultMode!='read'}">
                                        <lightning:textarea class="350" name="" label="" value="{!investigator.investigatorRecord.Experience_Relevant_to_this_Proposal__c}" onchange="{!c.validateTextArea}"/>
                                    </aura:if>
                                    <aura:if isTrue="{!v.defaultMode=='read'}">
                                        {!investigator.investigatorRecord.Experience_Relevant_to_this_Proposal__c}
                                    </aura:if>
                                </div>
                                <div class="slds-col slds-size_1-of-1 slds-large-size_12-of-12">
                                    <br/>
                                    <div class="slds-progress__item_content slds-grid slds-grid_align-spread QuestionClass">Q9. Research output in last 5 years </div><br/>
                                </div>
                                <div class="slds-col slds-size_1-of-1 slds-large-size_12-of-12">
                                    <div class="slds-progress__item_content slds-grid slds-grid_align-spread QuestionClass">Please list only 10 most relevant among of the following:</div><br/>
                                    <div class="slds-progress__item_content slds-grid slds-grid_align-spread QuestionClass">•	Peer-reviewed publications. List should include peer reviewed research articles, systematic reviews and meta-analyses, but exclude abstracts and literature reviews. Please provide PubMed Central ID (PMCID) reference for each. </div>
                                    <div class="slds-progress__item_content slds-grid slds-grid_align-spread QuestionClass">•	Preprints. List should include manuscripts that have been submitted to a preprint repository or service. Please provide full citation, including title of paper, all authors, along with repository’s name and the article identifier. It is mandatory to mention a permanent identifier such as DOI. </div>
                                    <div class="slds-progress__item_content slds-grid slds-grid_align-spread QuestionClass">•	Inventions and patents. Please provide title, authors, granting agency, patent number, year and status of the application. </div><br/>
                                    <div class="slds-progress__item_content slds-grid slds-grid_align-spread QuestionClass">Guidelines:</div><br/>
                                    <div class="slds-progress__item_content slds-grid slds-grid_align-spread QuestionClass">•	The author details including the author order and corresponding author information must be accurate and as per the published article. Improper representation of credit or authorship would be considered as a serious misconduct by India Alliance and may lead to rejection of the application.</div>
                                    <div class="slds-progress__item_content slds-grid slds-grid_align-spread QuestionClass">•	Publications should have names of all authors. “et al” should not be used unless there are more than 06 authors. “et al” should not be used unless there are more than 06 authors. Please use Vancouver referencing style. </div>
                                    <div class="slds-progress__item_content slds-grid slds-grid_align-spread QuestionClass">•	All entries should be in chronological order, with most recent first. Use sub-headings to segregate the list (such as research articles, preprints, patents, etc.)</div>
                                    <div class="slds-progress__item_content slds-grid slds-grid_align-spread QuestionClass">•	Use asterisks (*) to highlight if you are a corresponding author (along with other co-corresponding authors) and underline if you are a joint-first author.</div>
                                    <div class="slds-progress__item_content slds-grid slds-grid_align-spread QuestionClass">•	Please provide number of citations at present in bracket at the end of each entry.</div>
                                    <div class="slds-progress__item_content slds-grid slds-grid_align-spread QuestionClass">•	Please do not list the journal Impact Factor.</div>
                                    <br/>
                                    <aura:if isTrue="{!v.defaultMode!='read'}">
                                        <lightning:inputRichText value="{!investigator.investigatorRecord.Research_Output_in_last_5_years__c}" placeholder=""/>
                                        <!--<lightning:textarea maxlength="" name="" label="" value="{!investigator.investigatorRecord.Research_Output_in_last_5_years__c}"/>-->
                                    </aura:if>
                                    <aura:if isTrue="{!v.defaultMode=='read'}">
                                        <lightning:formattedRichText value="{!investigator.investigatorRecord.Research_Output_in_last_5_years__c}" />
                                    </aura:if>
                                </div>
                                <div class="slds-col slds-size_1-of-1 slds-large-size_12-of-12">
                                    <br/>
                                    <div class="slds-progress__item_content slds-grid slds-grid_align-spread QuestionClass">Q10. Other financial support </div><br/>
                                </div>
                                
                                <div class="slds-col slds-size_1-of-1 slds-large-size_12-of-12">
                                    <div class="slds-progress__item_content slds-grid slds-grid_align-spread">Please list all upto 10 key financial support that you have received in the last five years (research grants, fellowships, commercial etc.), with the most recent first. The information provided should state: (i) Name of the funder; (ii) Name(s) of recipient(s); (iii) Title of the project; (iv) Awarded Budget with currencies; (v)Your role in the project; and (vi) Start and end dates of project. For all active awards, indicate the number of hours per week that you spend on each project.</div>
                                    <br/>
                                    <lightning:select variant="label-hidden" label="" value="{!investigator.investigatorRecord.Is_other_financial_support__c}" disabled="{!v.defaultMode=='read'}">
                                        <option value="Yes">Yes</option>
                                        <option value="No">No</option>
                                    </lightning:select>
                                    <br/>
                                    <aura:if isTrue="{!investigator.investigatorRecord.Is_other_financial_support__c =='Yes'}">
                                        <aura:if isTrue="{!v.defaultMode!='read'}"><div style="text-align:right;"><lightning:button variant="" label="Add Other Financial Support" value="{! investigator.investigatorRecord.Id}" name="v.showAddOFS" class="invIdofs" title="Add Other Financial Support" onclick="{! c.openModal }" /></div></aura:if>
                                        <div class="tableScroll">
                                            
                                            <table class="slds-table slds-table_cell-buffer slds-table_bordered">
                                                <thead>
                                                    <tr class="slds-line-height_reset">
                                                        <th class="nowrap" scope="col">
                                                            <div class=" " title="Name of the funder">Name of the funder</div>
                                                        </th>
                                                        <th class="nowrap" scope="col">
                                                            <div class=" " title="Name(s) of recipient">Name(s) of recipient</div>
                                                        </th>  
                                                        <th class="nowrap" scope="col">
                                                            <div class=" " title="Title of the project">Title of the project</div>
                                                        </th> 
                                                        <th class="nowrap" scope="col">
                                                            <div class=" " title=" Awarded Budget with currencies"> Awarded Budget with currencies</div>
                                                        </th>
                                                        <th class="nowrap" scope="col">
                                                            <div class=" " title="Your role in the project">Your role in the project</div>
                                                        </th>
                                                        <th class="nowrap" scope="col">
                                                            <div class=" " title="Start Date">Start Date</div>
                                                        </th>
                                                        <th class="nowrap" scope="col">
                                                            <div class=" " title="End Date">End Date</div>
                                                        </th>
                                                        <aura:if isTrue="{!v.defaultMode!='read'}">
                                                            <th class="nowrap" scope="col">
                                                                <div class=" " title="Action">Action </div>
                                                            </th>
                                                        </aura:if>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    <aura:iteration var="ofc" items="{!investigator.otherFinancialSupportList}" indexVar="indx">
                                                        <tr>
                                                            <th class="" scope="col">
                                                                <div class=" " title="{!ofc.Name_of_the_funder__c}">{!ofc.Name_of_the_funder__c}</div>
                                                            </th>
                                                            <th class="" scope="col">
                                                                <div class=" " title="{!ofc.Name_s_of_recipient__c}">{!ofc.Name_s_of_recipient__c}</div>
                                                            </th>
                                                            <th class="" scope="col">
                                                                <div class=" " title="{!ofc.Title_of_the_project__c}">{!ofc.Title_of_the_project__c}</div>
                                                            </th>
                                                            <th class="" scope="col">
                                                                <div class=" " title="{!ofc.Awarded_Budget_with_currencies__c}">{!ofc.Awarded_Budget_with_currencies__c}</div>
                                                            </th>
                                                            <th class="" scope="col">
                                                                <div class=" " title="{!ofc.Your_role_in_the_project__c}">{!ofc.Your_role_in_the_project__c}</div>
                                                            </th>
                                                            <th class="nowrap" scope="col">
                                                                <div class=" " title="{!ofc.Start_Date__c}">{!ofc.Start_Date__c}</div>
                                                            </th>
                                                            <th class="nowrap" scope="col">
                                                                <div class=" " title="{!ofc.End_Date__c}">{!ofc.End_Date__c}</div>
                                                            </th>
                                                            <aura:if isTrue="{!v.defaultMode!='read'}">
                                                                <th class="nowrap" scope="col">
                                                                    <div class=" ">
                                                                        <lightning:button variant="neutral" label="Edit" title="Edit" value="{! ofc.Id}" name="v.showAddOFS" onclick="{! c.editRecord }"/>
                                                                        <lightning:button variant="neutral" label="Remove" title="Remove" value="{!ofc.Id}" onclick="{! c.removeRecord }" /></div>
                                                                </th>
                                                            </aura:if>
                                                        </tr>
                                                    </aura:iteration>
                                                </tbody>
                                            </table>
                                            
                                        </div>
                                    </aura:if>
                                </div>
                                <aura:if isTrue="{!investigator.investigatorRecord.Is_other_financial_support__c =='Yes'}">
                                    <div class="slds-col slds-size_1-of-1 slds-large-size_12-of-12">
                                        <br/>
                                        <div class="slds-progress__item_content slds-grid slds-grid_align-spread QuestionClass">Q11.	Please describe how the current active awards listed above relate to this application (Limit 200 words)</div>
                                    </div>
                                    <div class="slds-col slds-size_1-of-1 slds-large-size_12-of-12">
                                        <aura:if isTrue="{!v.defaultMode!='read'}">
                                            <lightning:textarea class="200" name="" label="" value="{!investigator.investigatorRecord.Describe_the_Current_Active_Awards__c}" onchange="{!c.validateTextArea}"/>
                                        </aura:if>
                                        <aura:if isTrue="{!v.defaultMode=='read'}">
                                            {!investigator.investigatorRecord.Describe_the_Current_Active_Awards__c}
                                        </aura:if>
                                    </div>
                                </aura:if>
                                <div class="slds-col slds-size_1-of-1 slds-large-size_12-of-12">
                                    <br/>
                                    <aura:if isTrue="{!investigator.investigatorRecord.Is_other_financial_support__c =='Yes'}">
                                        <div class="slds-progress__item_content slds-grid slds-grid_align-spread QuestionClass">Q12. Clinical status. These questions should be answered by only those PIs who have a medical/dental degree.</div>
                                    </aura:if>
                                    <aura:if isTrue="{!investigator.investigatorRecord.Is_other_financial_support__c !='Yes'}">
                                        <div class="slds-progress__item_content slds-grid slds-grid_align-spread QuestionClass">Q11. Clinical status. These questions should be answered by only those PIs who have a medical/dental degree.</div>
                                    </aura:if>
                                </div>
                                <div class="slds-col slds-size_1-of-1 slds-large-size_12-of-12">
                                    <div class="slds-progress__item_content slds-grid slds-grid_align-spread">(a) Please specify your medical degree</div>
                                    <aura:if isTrue="{!v.defaultMode!='read'}">
                                        <lightning:textarea class="100" name="" label="" value="{!investigator.investigatorRecord.Please_specify_your_medical_degree__c}" onchange="{!c.validateTextArea}"/>
                                    </aura:if>
                                    <aura:if isTrue="{!v.defaultMode=='read'}">
                                        {!investigator.investigatorRecord.Please_specify_your_medical_degree__c}
                                    </aura:if>
                                </div>
                                <div class="slds-col slds-size_1-of-1 slds-large-size_12-of-12">
                                    <div class="slds-progress__item_content slds-grid slds-grid_align-spread">(b) If you are clinically active, what is your specialty?</div>
                                    <aura:if isTrue="{!v.defaultMode!='read'}">
                                        <lightning:textarea class="200" name="" label="" value="{!investigator.investigatorRecord.what_is_your_specialty_Active__c}" onchange="{!c.validateTextArea}"/>
                                    </aura:if>
                                    <aura:if isTrue="{!v.defaultMode=='read'}">
                                        {!investigator.investigatorRecord.what_is_your_specialty_Active__c}
                                    </aura:if>
                                </div>
                                <div class="slds-col slds-size_1-of-1 slds-large-size_12-of-12">
                                    <br/>
                                    <aura:if isTrue="{!investigator.investigatorRecord.Is_other_financial_support__c =='Yes'}">
                                        <div class="slds-progress__item_content slds-grid slds-grid_align-spread QuestionClass">Q13. Related applications</div> 
                                    </aura:if>
                                    <aura:if isTrue="{!investigator.investigatorRecord.Is_other_financial_support__c !='Yes'}">
                                        <div class="slds-progress__item_content slds-grid slds-grid_align-spread QuestionClass">Q12. Related applications</div> 
                                    </aura:if>
                                </div>
                                <div class="slds-col slds-size_1-of-1 slds-large-size_12-of-12">
                                    <div class="slds-progress__item_content slds-grid slds-grid_align-spread">Has a similar application been submitted / will be submitted for funding elsewhere? If yes, please provide following details: (i) Name of the funding organisation; (ii) Expected decision date; and (iii) Brief summary (under 200 words) of the other application including aims and overlap with the current proposal. </div>
                                    <!--<aura:if isTrue="{!v.defaultMode!='read'}">
                                        <lightning:textarea maxlength="" name="" label="" value="{!investigator.investigatorRecord.Related_applications__c}" />
                                    </aura:if>
                                    <aura:if isTrue="{!v.defaultMode=='read'}">
                                        {!investigator.investigatorRecord.Related_applications__c}
                                    </aura:if>-->
                                    <lightning:select variant="label-hidden" label="" value="{!investigator.investigatorRecord.Will_be_submitted_for_funding__c}" disabled="{!v.defaultMode=='read'}">
                                        <option value="Yes">Yes</option>
                                        <option value="No">No</option>
                                    </lightning:select>
                                    <br/>
                                    <aura:if isTrue="{!investigator.investigatorRecord.Will_be_submitted_for_funding__c =='Yes'}">
                                        <aura:if isTrue="{!v.defaultMode!='read'}"><div style="text-align:right;"><lightning:button variant="" label="Add Funding Organisation" value="{! investigator.investigatorRecord.Id}" name="v.showAddFO" class="invIdfo" title="Add Funding Organisation" onclick="{! c.openModal }" /></div></aura:if>
                                        
                                        <div class="tableScroll">
                                            <table class="slds-table slds-table_cell-buffer slds-table_bordered">
                                                <thead>
                                                    <tr class="slds-line-height_reset">
                                                        <th class="nowrap" scope="col">
                                                            <div class=" " title="Name of the funding organisation">Name of the funding organisation</div>
                                                        </th>
                                                        <th class="nowrap" scope="col">
                                                            <div class=" " title="Expected decision date">Expected decision date</div>
                                                        </th>  
                                                        <th class="nowrap" scope="col" style="width: 500px;">
                                                            <div class=" " title="Brief summary">Brief summary</div>
                                                        </th> 
                                                        <aura:if isTrue="{!v.defaultMode!='read'}">
                                                            <th class="nowrap" scope="col">
                                                                <div class=" " title="Action">Action </div>
                                                            </th>
                                                        </aura:if>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    <aura:iteration var="fo" items="{!investigator.fundingOrganisationList}" indexVar="indx">
                                                        <tr>
                                                            <th class="" scope="col">
                                                                <div class=" " title="{!fo.Name_of_the_funding_organisation__c}">{!fo.Name_of_the_funding_organisation__c}</div>
                                                            </th>
                                                            <th class="" scope="col">
                                                                <div class=" " title="{!fo.Expected_decision_date__c}">{!fo.Expected_decision_date__c}</div>
                                                            </th>
                                                            <th class="" scope="col">
                                                                <div class=" " title="{!fo.Brief_summary_under_200_words__c}">{!fo.Brief_summary_under_200_words__c}</div>
                                                            </th>
                                                            <aura:if isTrue="{!v.defaultMode!='read'}">
                                                                <th class="nowrap" scope="col">
                                                                    <div class=" ">
                                                                        <lightning:button variant="neutral" label="Edit" title="Edit" value="{! fo.Id}" name="v.showAddFO" onclick="{! c.editRecord }"/>
                                                                        <lightning:button variant="neutral" label="Remove" title="Remove" value="{!fo.Id}" onclick="{! c.removeRecord }" /></div>
                                                                </th>
                                                            </aura:if>
                                                        </tr>
                                                    </aura:iteration>
                                                </tbody>
                                            </table>
                                        </div>
                                        
                                    </aura:if>
                                    <br/><br/>
                                </div>
                            </div>
                        </aura:iteration>
                        <aura:iteration var="investigator" items="{!v.form.investigatorRecordListPH}" indexVar="indx">
                            <div class="{!v.form.selectedPI == investigator.investigatorRecord.Id  ? 'slds-show' : 'slds-hide'}">
                                <div class="slds-progress__item_content slds-grid slds-grid_align-spread QuestionClass">Q1. Provide details and CVs of all Investigators (PIs, co-PIs).</div>
                                <div class="slds-col slds-size_1-of-1 slds-large-size_12-of-12">
                                    <table class="slds-table slds-table_cell-buffer slds-table_bordered">
                                        <tbody>
                                            
                                            <tr class="slds-line-height_reset">
                                                <th class="" scope="col" width="30">
                                                    <div class=" " title="">Role (Choose appropriately)</div>
                                                </th>
                                                <th class="" scope="col" width="70">
                                                    <div class=" " title="{!investigator.investigatorRecord.Role__c}">{!investigator.investigatorRecord.Role__c}</div>
                                                </th>
                                            </tr>
                                            <tr class="slds-line-height_reset">
                                                <th class="" scope="col" width="30">
                                                    <div class=" " title="Full Name">Full Name</div>
                                                </th>
                                                <th class="" scope="col">
                                                    <div class=" " title="{!investigator.investigatorRecord.Full_Name__c}">{!investigator.investigatorRecord.Full_Name__c}</div>
                                                </th>
                                            </tr>
                                            <tr class="slds-line-height_reset">
                                                <th class="" scope="col" width="30">
                                                    <div class=" " title="Date of Birth (DD/MM/YYYY):">Date of Birth (DD/MM/YYYY)</div>
                                                </th>
                                                <th class="" scope="col">
                                                    <div class=" " title="{!investigator.investigatorRecord.Date_of_Birth__c}">{!investigator.investigatorRecord.Date_of_Birth__c}</div>
                                                </th>
                                            </tr>
                                            <tr class="slds-line-height_reset">
                                                <th class="" scope="col" width="30">
                                                    <div class=" " title="Nationality">Nationality</div>
                                                </th>
                                                <th class="" scope="col">
                                                    <div class=" " title="{!investigator.investigatorRecord.Nationality__c}">{!investigator.investigatorRecord.Nationality__c}</div>
                                                </th>
                                            </tr>
                                            <tr class="slds-line-height_reset">
                                                <th class="" scope="col" width="30">
                                                    <div class=" " title="Gender">Gender</div>
                                                </th>
                                                <th class="" scope="col">
                                                    <div class=" " title="{!investigator.investigatorRecord.Gender__c}">{!investigator.investigatorRecord.Gender__c}</div>
                                                </th>
                                            </tr>
                                            <tr class="slds-line-height_reset">
                                                <th class="" scope="col" width="30">
                                                    <div class=" " title="Direct contact number:(The office may contact you on this number). ">Direct contact number:<br/>(The office may contact you on this number). </div>
                                                </th>
                                                <th class="" scope="col">
                                                    <div class=" " title="{!investigator.investigatorRecord.Contact_Number__c}">{!investigator.investigatorRecord.Contact_Number__c}</div>
                                                </th>
                                            </tr>
                                            <tr class="slds-line-height_reset">
                                                <th class="" scope="col" width="30">
                                                    <div class=" " title="Email ID">Email ID</div>
                                                </th>
                                                <th class="" scope="col">
                                                    <div class=" " title="{!investigator.investigatorRecord.Email__c}">{!investigator.investigatorRecord.Email__c}</div>
                                                </th>
                                            </tr>
                                            <tr class="slds-line-height_reset">
                                                <th class="" scope="col" width="30">
                                                    <div class=" " title="Expertise">Expertise</div>
                                                </th>
                                                <th class="" scope="col">
                                                    <div class=" " title="{!investigator.investigatorRecord.Discipline_expertise__c}">{!investigator.investigatorRecord.Discipline_expertise__c}</div>
                                                </th>
                                            </tr>
                                            <tr class="slds-line-height_reset">
                                                <th class="" scope="col" width="30">
                                                    <div class=" " title="ORCID ID">ORCID ID</div>
                                                </th>
                                                <th class="" scope="col">
                                                    <div class=" " title="{!investigator.investigatorRecord.ORCID_ID__c}">{!investigator.investigatorRecord.ORCID_ID__c}</div>
                                                </th>
                                            </tr>
                                        </tbody>
                                    </table>
                                    <br/>
                                </div>
                                <div class="slds-col slds-size_1-of-1 slds-large-size_12-of-12">
                                    <br/>
                                    <div class="slds-progress__item_content slds-grid slds-grid_align-spread QuestionClass">Q2. Current position</div>
                                </div>
                                <div class="slds-col slds-size_1-of-1 slds-large-size_12-of-12 tableScroll">
                                    
                                    <table class="slds-table slds-table_cell-buffer slds-table_bordered">
                                        <tbody>
                                            <tr class="slds-line-height_reset">
                                                <th class="nowrap" scope="col" width="30">
                                                    <div class=" " title="Name of the institution">Name of the institution</div>
                                                </th>
                                                <th class="" scope="col">
                                                    <div class=" " title="{!investigator.investigatorRecord.Institution__r.Name}">{!investigator.investigatorRecord.Institution__r.Name}</div>
                                                </th>
                                            </tr>
                                            <tr class="slds-line-height_reset">
                                                <th class="nowrap" scope="col" width="30">
                                                    <div class=" " title="Name of the Sponsor ">Name of the Sponsor <br/><i>Check Sponsor and Sponsoring Institutes <a href="https://www.indiaalliance.org/team-science-grants" target="_blank">here</a></i></div>
                                                </th>
                                                <th class="" scope="col">
                                                    <aura:if isTrue="{!v.defaultMode!='read'}">
                                                        <lightning:input maxlength="" name="" label="" value="{!investigator.investigatorRecord.Name_of_the_Sponsor__c}"/>
                                                    </aura:if>
                                                    <aura:if isTrue="{!v.defaultMode=='read'}">
                                                        {!investigator.investigatorRecord.Name_of_the_Sponsor__c}
                                                    </aura:if>
                                                    
                                                </th>
                                            </tr>
                                            <tr class="slds-line-height_reset">
                                                <th class="nowrap" scope="col" width="30">
                                                    <div class=" " title="Email of the Sponsor">Email of the Sponsor</div>
                                                </th>
                                                <th class="" scope="col">
                                                    <aura:if isTrue="{!v.defaultMode!='read'}">
                                                        <lightning:input maxlength="" name="" label="" value="{!investigator.investigatorRecord.Email_of_the_Sponsor__c}"/>
                                                    </aura:if>
                                                    <aura:if isTrue="{!v.defaultMode=='read'}">
                                                        {!investigator.investigatorRecord.Email_of_the_Sponsor__c}
                                                    </aura:if>
                                                </th>
                                            </tr>
                                            <tr class="slds-line-height_reset">
                                                <th class="nowrap" scope="col" width="30">
                                                    <div class=" " title="(a) Title of current post">(a) Title of current post</div>
                                                </th>
                                                <th class="" scope="col">
                                                    <aura:if isTrue="{!v.defaultMode!='read'}">
                                                        <lightning:input  maxlength="" name="" label="" value="{!investigator.investigatorRecord.Title_of_current_Post__c}"/>
                                                    </aura:if>
                                                    <aura:if isTrue="{!v.defaultMode=='read'}">
                                                        {!investigator.investigatorRecord.Title_of_current_Post__c}
                                                    </aura:if>
                                                </th>
                                            </tr> 
                                            <tr>
                                                <th class="" scope="col" colspan="2">
                                                    <div class="nowrap" title="(b) With whom do you have your contract of employment? ">(b) With whom do you have your contract of employment? </div>
                                                    <aura:if isTrue="{!v.defaultMode!='read'}">
                                                        <lightning:textarea maxlength="" name="" label="" value="{!investigator.investigatorRecord.Your_Contract_of_Employment__c}"/>
                                                    </aura:if>
                                                    <aura:if isTrue="{!v.defaultMode=='read'}">
                                                        {!investigator.investigatorRecord.Your_Contract_of_Employment__c}
                                                    </aura:if>
                                                </th>
                                            </tr>
                                            <tr>
                                                <th class="" scope="col" colspan="2">
                                                    <div class="nowrap" title="(c) Source of personal salary support">(c) Source of personal salary support<br/><i><br/>Also be specific if your current salary is funded from more than one source. Indicate with an asterisk (*) those sources of salary support that have contributed to the background of this proposal. </i></div>
                                                    <aura:if isTrue="{!v.defaultMode!='read'}">
                                                        <lightning:textarea maxlength="" name="" label="" value="{!investigator.investigatorRecord.Source_of_personal_salary_support__c}"/>
                                                    </aura:if>
                                                    <aura:if isTrue="{!v.defaultMode=='read'}">
                                                        {!investigator.investigatorRecord.Source_of_personal_salary_support__c}
                                                    </aura:if>
                                                </th>
                                            </tr> 
                                            <tr>
                                                <th class="nowrap" scope="col" colspan="2">
                                                    <div class=" " title="(d) Other affiliations in any other organization">(d) Other affiliations in any other organization</div>
                                                    <aura:if isTrue="{!v.defaultMode!='read'}">
                                                        <lightning:textarea maxlength="" name="" label="" value="{!investigator.investigatorRecord.Other_affiliations__c}"/>
                                                    </aura:if>
                                                    <aura:if isTrue="{!v.defaultMode=='read'}">
                                                        {!investigator.investigatorRecord.Other_affiliations__c}
                                                    </aura:if>
                                                </th>
                                            </tr> 
                                        </tbody>
                                    </table>  
                                    <br/>
                                </div>
                                <div class="slds-col slds-size_1-of-1 slds-large-size_12-of-12">
                                    <br/>
                                    <div class="slds-progress__item_content slds-grid slds-grid_align-spread QuestionClass">Q3. Highest Degree (PhD/MD/MBBS-MS/MD-PhD/MPH/equivalent)</div>
                                </div>
                                <div class="slds-col slds-size_1-of-1 slds-large-size_12-of-12">
                                    <aura:if isTrue="{!v.defaultMode!='read'}">
                                        <lightning:input maxlength="" name="" label="" value="{!investigator.investigatorRecord.Highest_Degree__c}"/>
                                    </aura:if>
                                    <aura:if isTrue="{!v.defaultMode=='read'}">
                                        {!investigator.investigatorRecord.Highest_Degree__c}
                                    </aura:if>
                                    
                                </div>
                                <div class="slds-col slds-size_1-of-1 slds-large-size_12-of-12">
                                    <br/>
                                    <div class="slds-progress__item_content slds-grid slds-grid_align-spread QuestionClass">Q4. For how many years have you been running an independent research group or lab?<i>Please exclude your non-research career break, if any.</i></div>
                                </div>
                                <div class="slds-col slds-size_1-of-1 slds-large-size_12-of-12">
                                    <aura:if isTrue="{!v.defaultMode!='read'}">
                                        <lightning:input type="number" maxlength="" name="" label="" value="{!investigator.investigatorRecord.Years_of_Running_Research_Group_Lab__c}"/>
                                    </aura:if>
                                    <aura:if isTrue="{!v.defaultMode=='read'}">
                                        {!investigator.investigatorRecord.Years_of_Running_Research_Group_Lab__c}
                                    </aura:if>
                                </div>
                                <div class="slds-col slds-size_1-of-1 slds-large-size_12-of-12">
                                    <br/>
                                    <div class="slds-progress__item_content slds-grid slds-grid_align-spread QuestionClass">Q5. Previous posts held (list the most recent first)<aura:if isTrue="{!v.defaultMode!='read'}"><div style="text-align:right;"><lightning:button variant="neutral" value="{! investigator.investigatorRecord.Id}" name="v.showAddPost" class="InvId" label="Add Post" title="Add Post" onclick="{! c.openModal }" /></div></aura:if></div>
                                </div>
                                <div class="slds-col slds-size_1-of-1 slds-large-size_12-of-12">
                                    <br/>
                                    <table class="slds-table slds-table_cell-buffer slds-table_bordered">
                                        <thead>
                                            <tr class="slds-line-height_reset">
                                                <th class="" scope="col">
                                                    <div class=" " title="Date from (mm/yyyy) ">Date from (mm/yyyy)</div>
                                                </th>
                                                <th class="" scope="col">
                                                    <div class=" " title="Date to (mm/yyyy) ">Date to (mm/yyyy)</div>
                                                </th>
                                                <th class="" scope="col">
                                                    <div class=" " title="Position">Position</div>
                                                </th>
                                                <th class="" scope="col">
                                                    <div class=" " title="Department">Department</div>
                                                </th>
                                                <th class="" scope="col">
                                                    <div class=" " title="Organisation">Organisation</div>
                                                </th>
                                                <aura:if isTrue="{!v.defaultMode!='read'}">
                                                    <th class="" scope="col">
                                                        <div class=" " title="Action">Action</div>
                                                    </th>
                                                </aura:if>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <aura:iteration var="ph" items="{!investigator.phList}">
                                                <tr class="slds-line-height_reset">
                                                    <th class="" scope="col">
                                                        <div class=" " title="{!ph.Date_From__c}">{!ph.Date_From__c}</div>
                                                    </th>
                                                    <th class="" scope="col">
                                                        <div class=" " title="{!ph.Date_To__c}">{!ph.Date_To__c}</div>
                                                    </th>
                                                    <th class="" scope="col">
                                                        <div class=" " title="{!ph.Name }">{!ph.Position__c }</div>
                                                    </th>
                                                    <th class="" scope="col">
                                                        <div class=" " title="{!ph.Department__c}">{!ph.Department__c}</div>
                                                    </th>
                                                    <th class="" scope="col">
                                                        <div class=" " title="{!ph.Organisations__r.Name}">{!ph.Organisations__r.Name} </div>
                                                    </th>
                                                    <aura:if isTrue="{!v.defaultMode!='read'}">
                                                        <th>
                                                            <lightning:button variant="neutral" label="Edit" title="Edit" value="{! ph.Id}" name="v.showAddPost" onclick="{! c.editRecord }"/>
                                                            <lightning:button variant="neutral" value="{! ph.Id}" label="Remove" title="Remove" onclick="{! c.removeRecord }" />
                                                        </th>
                                                    </aura:if>
                                                </tr>
                                            </aura:iteration>
                                        </tbody>
                                    </table>
                                </div> 
                                <div class="slds-col slds-size_1-of-1 slds-large-size_12-of-12">
                                    <br/>
                                    <div class="slds-progress__item_content slds-grid slds-grid_align-spread QuestionClass">Q6. Education/training (list the most recent first)<aura:if isTrue="{!v.defaultMode!='read'}"><div style="text-align:right;"><lightning:button variant="neutral" value="{! investigator.investigatorRecord.Id}" label="Add Education/Training" name="v.showAddEducation" class="InvIdEdu" title="Add Education/Training" onclick="{! c.openModal }" /></div></aura:if></div>
                                </div>
                                <div class="slds-col slds-size_1-of-1 slds-large-size_12-of-12">
                                    <br/>
                                    <table class="slds-table slds-table_cell-buffer slds-table_bordered">
                                        <thead>
                                            <tr class="slds-line-height_reset">
                                                <th class="" scope="col"> 
                                                    <div class=" " title="Date from (mm/yyyy) ">Date from (mm/yyyy)</div>
                                                </th>
                                                <th class="" scope="col">
                                                    <div class=" " title="Date to (mm/yyyy) ">Date to (mm/yyyy)</div>
                                                </th>
                                                <th class="" scope="col">
                                                    <div class=" " title="Qualification">Qualification</div>
                                                </th>
                                                <th class="" scope="col">
                                                    <div class=" " title="Subject">Subject</div>
                                                </th>
                                                <th class="" scope="col">
                                                    <div class=" " title="Organisation">Organisation</div>
                                                </th>
                                                <aura:if isTrue="{!v.defaultMode!='read'}">
                                                    <th class="" scope="col">
                                                        <div class=" " title="Action">Action</div>
                                                    </th>
                                                </aura:if>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <aura:iteration var="quly" items="{!investigator.qualificationlList}">
                                                <tr class="slds-line-height_reset">
                                                    <th class="" scope="col">
                                                        <div class=" " title="{!quly.Date_From__c}">{!quly.Date_From__c}</div>
                                                    </th>
                                                    <th class="" scope="col">
                                                        <div class=" " title="{!quly.Date_To__c}">{!quly.Date_To__c}</div>
                                                    </th>
                                                    <th class="" scope="col">
                                                        <div class=" " title="{!quly.Name}">{!quly.Qualification__c}</div>
                                                    </th>
                                                    <th class="" scope="col">
                                                        <div class=" " title="{!quly.Subject__c}">{!quly.Subject__c}</div>
                                                    </th>
                                                    <th class="" scope="col">
                                                        <div class=" " title="{!quly.Organisation__r.Name}">{!quly.Organisation__r.Name}</div>
                                                    </th>
                                                    <aura:if isTrue="{!v.defaultMode!='read'}">
                                                        <th>
                                                            <lightning:button variant="neutral" label="Edit" title="Edit" value="{! quly.Id}" name="v.showAddEducation" onclick="{! c.editRecord }"/>
                                                            <lightning:button variant="neutral" value="{! quly.Id}" label="Remove" title="Remove" onclick="{! c.removeRecord }" />
                                                        </th>
                                                    </aura:if>
                                                </tr>
                                            </aura:iteration>
                                        </tbody>
                                    </table>
                                </div>
                                
                                <div class="slds-col slds-size_1-of-1 slds-large-size_12-of-12">
                                    <br/>
                                    <div class="slds-progress__item_content slds-grid slds-grid_align-spread QuestionClass">Q7. Summary of scientific career to date, including key achievements (Limit 350 words)</div>
                                </div>
                                <div class="slds-col slds-size_1-of-1 slds-large-size_12-of-12">
                                    <aura:if isTrue="{!v.defaultMode!='read'}">
                                        <lightning:textarea class="350" name="" label="" onchange="{!c.validateTextArea}" value="{!investigator.investigatorRecord.Summary_of_Scientific_Career_to_Date__c}"/>
                                    </aura:if>
                                    <aura:if isTrue="{!v.defaultMode=='read'}">
                                        {!investigator.investigatorRecord.Summary_of_Scientific_Career_to_Date__c}
                                    </aura:if>
                                </div>
                                <div class="slds-col slds-size_1-of-1 slds-large-size_12-of-12">
                                    <br/>
                                    <div class="slds-progress__item_content slds-grid slds-grid_align-spread QuestionClass">Q8. Experience relevant to this proposal (Limit 350 words)</div>
                                </div>
                                <div class="slds-col slds-size_1-of-1 slds-large-size_12-of-12">
                                    <aura:if isTrue="{!v.defaultMode!='read'}">
                                        <lightning:textarea class="350" name="" onchange="{!c.validateTextArea}" label="" value="{!investigator.investigatorRecord.Experience_Relevant_to_this_Proposal__c}"/>
                                    </aura:if>
                                    <aura:if isTrue="{!v.defaultMode=='read'}">
                                        {!investigator.investigatorRecord.Experience_Relevant_to_this_Proposal__c}
                                    </aura:if>
                                </div>
                                <div class="slds-col slds-size_1-of-1 slds-large-size_12-of-12">
                                    <br/>
                                    <div class="slds-progress__item_content slds-grid slds-grid_align-spread QuestionClass">Q9. Research output in last 5 years </div><br/>
                                </div>
                                <div class="slds-col slds-size_1-of-1 slds-large-size_12-of-12"> 
                                    <div class="slds-progress__item_content slds-grid slds-grid_align-spread QuestionClass">Please list only 10 most relevant among of the following:</div><br/>
                                    <div class="slds-progress__item_content slds-grid slds-grid_align-spread QuestionClass">•	Peer-reviewed publications. List should include peer reviewed research articles, systematic reviews and meta-analyses, but exclude abstracts and literature reviews. Please provide PubMed Central ID (PMCID) reference for each. </div>
                                    <div class="slds-progress__item_content slds-grid slds-grid_align-spread QuestionClass">•	Preprints. List should include manuscripts that have been submitted to a preprint repository or service. Please provide full citation, including title of paper, all authors, along with repository’s name and the article identifier. It is mandatory to mention a permanent identifier such as DOI. </div>
                                    <div class="slds-progress__item_content slds-grid slds-grid_align-spread QuestionClass">•	Inventions and patents. Please provide title, authors, granting agency, patent number, year and status of the application. </div><br/>
                                    <div class="slds-progress__item_content slds-grid slds-grid_align-spread QuestionClass">Guidelines:</div><br/>
                                    <div class="slds-progress__item_content slds-grid slds-grid_align-spread QuestionClass">•	The author details including the author order and corresponding author information must be accurate and as per the published article. Improper representation of credit or authorship would be considered as a serious misconduct by India Alliance and may lead to rejection of the application.</div>
                                    <div class="slds-progress__item_content slds-grid slds-grid_align-spread QuestionClass">•	Publications should have names of all authors. “et al” should not be used unless there are more than 06 authors. “et al” should not be used unless there are more than 06 authors. Please use Vancouver referencing style. </div>
                                    <div class="slds-progress__item_content slds-grid slds-grid_align-spread QuestionClass">•	All entries should be in chronological order, with most recent first. Use sub-headings to segregate the list (such as research articles, preprints, patents, etc.)</div>
                                    <div class="slds-progress__item_content slds-grid slds-grid_align-spread QuestionClass">•	Use asterisks (*) to highlight if you are a corresponding author (along with other co-corresponding authors) and underline if you are a joint-first author.</div>
                                    <div class="slds-progress__item_content slds-grid slds-grid_align-spread QuestionClass">•	Please provide number of citations at present in bracket at the end of each entry.</div>
                                    <div class="slds-progress__item_content slds-grid slds-grid_align-spread QuestionClass">•	Please do not list the journal Impact Factor.</div>
                                    <br/>
                                    <aura:if isTrue="{!v.defaultMode!='read'}">
                                        <lightning:inputRichText value="{!investigator.investigatorRecord.Research_Output_in_last_5_years__c}" placeholder=""/>
                                        <!--<lightning:textarea maxlength="" name="" label="" value="{!investigator.investigatorRecord.Research_Output_in_last_5_years__c}"/>-->
                                    </aura:if>
                                    <aura:if isTrue="{!v.defaultMode=='read'}">
                                        <lightning:formattedRichText value="{!investigator.investigatorRecord.Research_Output_in_last_5_years__c}" />
                                    </aura:if>
                                </div>
                                <div class="slds-col slds-size_1-of-1 slds-large-size_12-of-12">
                                    <br/>
                                    <div class="slds-progress__item_content slds-grid slds-grid_align-spread QuestionClass">Q10. Other financial support </div><br/>
                                </div>
                                <div class="slds-col slds-size_1-of-1 slds-large-size_12-of-12">
                                    <div class="slds-progress__item_content slds-grid slds-grid_align-spread">Please list all upto 10 key financial support that you have received in the last five years (research grants, fellowships, commercial etc.), with the most recent first. The information provided should state: (i) Name of the funder; (ii) Name(s) of recipient(s); (iii) Title of the project; (iv) Awarded Budget with currencies; (v)Your role in the project; and (vi) Start and end dates of project. For all active awards, indicate the number of hours per week that you spend on each project.</div>
                                    <br/>
                                    <lightning:select variant="label-hidden" label="" value="{!investigator.investigatorRecord.Is_other_financial_support__c}" disabled="{!v.defaultMode=='read'}">
                                        <option value="Yes">Yes</option>
                                        <option value="No">No</option>
                                    </lightning:select>
                                    <br/>
                                    <aura:if isTrue="{!investigator.investigatorRecord.Is_other_financial_support__c =='Yes'}">
                                        <aura:if isTrue="{!v.defaultMode!='read'}"><div style="text-align:right;"><lightning:button variant="" label="Add Other Financial Support" value="{! investigator.investigatorRecord.Id}" name="v.showAddOFS" class="invIdofs" title="Add Other Financial Support" onclick="{! c.openModal }" /></div></aura:if>
                                        <div class="tableScroll">
                                            
                                            <table class="slds-table slds-table_cell-buffer slds-table_bordered">
                                                <thead>
                                                    <tr class="slds-line-height_reset">
                                                        <th class="nowrap" scope="col">
                                                            <div class=" " title="Name of the funder">Name of the funder</div>
                                                        </th>
                                                        <th class="nowrap" scope="col">
                                                            <div class=" " title="Name(s) of recipient">Name(s) of recipient</div>
                                                        </th>  
                                                        <th class="nowrap" scope="col">
                                                            <div class=" " title="Title of the project">Title of the project</div>
                                                        </th> 
                                                        <th class="nowrap" scope="col">
                                                            <div class=" " title=" Awarded Budget with currencies"> Awarded Budget with currencies</div>
                                                        </th>
                                                        <th class="nowrap" scope="col">
                                                            <div class=" " title="Your role in the project">Your role in the project</div>
                                                        </th>
                                                        <th class="nowrap" scope="col">
                                                            <div class=" " title="Start Date">Start Date</div>
                                                        </th>
                                                        <th class="nowrap" scope="col">
                                                            <div class=" " title="End Date">End Date</div>
                                                        </th>
                                                        <aura:if isTrue="{!v.defaultMode!='read'}">
                                                            <th class="nowrap" scope="col">
                                                                <div class=" " title="Action">Action </div>
                                                            </th>
                                                        </aura:if>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    <aura:iteration var="ofc" items="{!investigator.otherFinancialSupportList}" indexVar="indx">
                                                        <tr>
                                                            <th class="" scope="col">
                                                                <div class=" " title="{!ofc.Name_of_the_funder__c}">{!ofc.Name_of_the_funder__c}</div>
                                                            </th>
                                                            <th class="" scope="col">
                                                                <div class=" " title="{!ofc.Name_s_of_recipient__c}">{!ofc.Name_s_of_recipient__c}</div>
                                                            </th>
                                                            <th class="" scope="col">
                                                                <div class=" " title="{!ofc.Title_of_the_project__c}">{!ofc.Title_of_the_project__c}</div> 
                                                            </th>
                                                            <th class="" scope="col">
                                                                <div class=" " title="{!ofc.Awarded_Budget_with_currencies__c}">{!ofc.Awarded_Budget_with_currencies__c}</div>
                                                            </th>
                                                            <th class="" scope="col">
                                                                <div class=" " title="{!ofc.Your_role_in_the_project__c}">{!ofc.Your_role_in_the_project__c}</div>
                                                            </th>
                                                            <th class="nowrap" scope="col">
                                                                <div class=" " title="{!ofc.Start_Date__c}">{!ofc.Start_Date__c}</div>
                                                            </th>
                                                            <th class="nowrap" scope="col">
                                                                <div class=" " title="{!ofc.End_Date__c}">{!ofc.End_Date__c}</div>
                                                            </th>
                                                            <aura:if isTrue="{!v.defaultMode!='read'}">
                                                                <th class="nowrap" scope="col">
                                                                    <div class=" ">
                                                                        <lightning:button variant="neutral" label="Edit" title="Edit" value="{! ofc.Id}" name="v.showAddOFS" onclick="{! c.editRecord }"/>
                                                                        <lightning:button variant="neutral" label="Remove" title="Remove" value="{!ofc.Id}" onclick="{! c.removeRecord }" /></div>
                                                                </th>
                                                            </aura:if>
                                                        </tr>
                                                    </aura:iteration>
                                                </tbody>
                                            </table>
                                            
                                        </div>
                                    </aura:if>
                                </div>
                                <aura:if isTrue="{!investigator.investigatorRecord.Is_other_financial_support__c =='Yes'}">
                                    <div class="slds-col slds-size_1-of-1 slds-large-size_12-of-12">
                                        <br/>
                                        <div class="slds-progress__item_content slds-grid slds-grid_align-spread QuestionClass">Q11.	Please describe how the current active awards listed above relate to this application. (Limit 200 words)</div>
                                    </div>
                                    <div class="slds-col slds-size_1-of-1 slds-large-size_12-of-12">
                                        <aura:if isTrue="{!v.defaultMode!='read'}">
                                            <lightning:textarea class="200" name="" label="" value="{!investigator.investigatorRecord.Describe_the_Current_Active_Awards__c}" onchange="{!c.validateTextArea}"/>
                                        </aura:if>
                                        <aura:if isTrue="{!v.defaultMode=='read'}">
                                            {!investigator.investigatorRecord.Describe_the_Current_Active_Awards__c}
                                        </aura:if>
                                    </div>
                                </aura:if>
                                <div class="slds-col slds-size_1-of-1 slds-large-size_12-of-12"> 
                                    <br/>
                                    <aura:if isTrue="{!investigator.investigatorRecord.Is_other_financial_support__c =='Yes'}">
                                        <div class="slds-progress__item_content slds-grid slds-grid_align-spread QuestionClass">Q12. Clinical status. These questions may not be relevant if you do not have a medical/dental degree. Include N/A if that is the case</div>
                                    </aura:if>
                                    <aura:if isTrue="{!investigator.investigatorRecord.Is_other_financial_support__c !='Yes'}">
                                        <div class="slds-progress__item_content slds-grid slds-grid_align-spread QuestionClass">Q11. Clinical status. These questions may not be relevant if you do not have a medical/dental degree. Include N/A if that is the case</div>
                                    </aura:if>
                                </div>
                                <div class="slds-col slds-size_1-of-1 slds-large-size_12-of-12">
                                    <div class="slds-progress__item_content slds-grid slds-grid_align-spread">(a) Please specify your medical degree</div>
                                    <aura:if isTrue="{!v.defaultMode!='read'}">
                                        <lightning:textarea maxlength="" name="" label="" value="{!investigator.investigatorRecord.Please_specify_your_medical_degree__c}"/>
                                    </aura:if>
                                    <aura:if isTrue="{!v.defaultMode=='read'}">
                                        {!investigator.investigatorRecord.Please_specify_your_medical_degree__c}
                                    </aura:if>
