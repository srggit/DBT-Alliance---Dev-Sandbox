                                                    <th class="nowrap" width="30" style="font-size: 5px;">
                                                        <lightning:fileUpload  name="fileUploader"
                                                                              label= "Upload Documents"
                                                                              multiple="true" 
                                                                              recordId="{!od.other_Document.Id}"
                                                                              onuploadfinished="{! c.handleUploadFinished }"/>
                                                        
                                                    </th>
                                                </aura:if>
                                            </tr>
                                            <aura:iteration var="cdl" items="{!od.contentDocumentLinkList}" indexVar="indx">
                                                <tr class="slds-line-height_reset">
                                                    <th class="" scope="col">
                                                        {!cdl.ContentDocument.Title}
                                                    </th>
                                                    <aura:if isTrue="{!v.defaultMode!='read'}">
                                                        <th class="nowrap" scope="col" width="30">
                                                            
                                                            <lightning:button variant="neutral" label="Remove" title="Remove" value="{! cdl.Id}" onclick="{! c.removeRecord }" />
                                                        </th>
                                                    </aura:if>
                                                </tr>
                                            </aura:iteration> 
                                        </tbody>
                                    </table>
                                    <br/>
                                </aura:iteration>
                            </div>
                        </div><br/>
                        <div class="slds-col slds-size_1-of-1 slds-large-size_12-of-12" style="text-align: right;">
                            <aura:if isTrue="{!v.defaultMode!='read'}">
                                <br/>
                                <ul class="slds-button-group-row">
                                    <li class="slds-button-group-item">
                                        <button class="slds-button slds-button_brand" onclick="{!c.save}">Save Draft</button>
                                    </li>
                                    <li class="slds-button-group-item">
                                        <lightning:button variant="brand" label="Save &amp; Previous" title="Save &amp; Previous" value="13" onclick="{! c.save }" />
                                    </li>
                                    <li class="slds-button-group-item">
                                        <lightning:button variant="brand" label="Save &amp; Next" title="Save &amp; Next" value="16" onclick="{! c.save }" />
                                    </li>
                                    <li class="slds-button-group-item">
                                        <button class="slds-button slds-button_brand" onclick="{!c.saveAndRedirect}">Cancel</button>
                                    </li>
                                </ul>
                            </aura:if>.
                            <aura:if isTrue="{!v.defaultMode=='read'}">
                                <ul class="slds-button-group-row">
                                    <li class="slds-button-group-item">
                                        <lightning:button variant="brand" label="Previous" title="Previous" value="13" onclick="{! c.next }" />
                                    </li>
                                    <li class="slds-button-group-item">
                                        <lightning:button variant="brand" label="Next" title="Next" value="16" onclick="{! c.next }" />
                                    </li>
                                </ul>
                            </aura:if>
                        </div>
                    </div>
                    <div class="{!v.currentStep == 'step16'? 'slds-show' : 'slds-hide'}">
                        <br/><br/>
                        <div class="slds-grid slds-wrap">
                            <div class="slds-col slds-size_1-of-1 slds-large-size_8-of-12"> 
                                <div class="slds-page-header__name">
                                    <div class="slds-page-header__name-title">
                                        <h1>
                                            <span class="slds-page-header__title  " title="Research Involving Human Participation"><aura:if isTrue="{! !v.form.isCRC}"><i>15. SDGs (Sustainable Development Goals)</i></aura:if>
                                                <aura:if isTrue="{! v.form.isCRC}"><i>16. SDGs (Sustainable Development Goals)</i></aura:if></span>
                                        </h1>
                                    </div>
                                </div>
                            </div>
                            <div class="slds-col slds-size_1-of-1 slds-large-size_4-of-12" style="text-align: right;">
                                <aura:if isTrue="{!v.defaultMode!='read'}">
                                    <ul class="slds-button-group-row">
                                        <li class="slds-button-group-item">
                                            <button class="slds-button slds-button_brand" onclick="{!c.save}">Save Draft</button>
                                        </li>
                                        <li class="slds-button-group-item">
                                            <lightning:button variant="brand" label="Save &amp; Previous" title="Save &amp; Previous" value="15" onclick="{! c.save }" />
                                        </li>
                                        <li class="slds-button-group-item">
                                            <button class="slds-button slds-button_brand" onclick="{!c.saveAndRedirect}">Cancel</button>
                                        </li>
                                    </ul>
                                </aura:if>
                                <aura:if isTrue="{!v.defaultMode=='read'}">
                                    <br/>
                                    <ul class="slds-button-group-row">
                                        <li class="slds-button-group-item">
                                            <lightning:button variant="brand" label="Previous" title="Previous" value="15" onclick="{! c.next }" />
                                        </li>
                                    </ul>
                                </aura:if>
                            </div>
                            <div class="slds-col slds-size_1-of-1 slds-large-size_12-of-12">
                                <br/><br/>
                                <div class="slds-progress__item_content slds-grid slds-grid_align-spread QuestionClass">Q1. How does your project help the following. If yes, please tick as appropriate </div><br/>
                                <aura:if isTrue="{!v.defaultMode!='read'}">
                                    <ui:inputCheckbox label="Sustainable Development Goals" value="{!v.form.grantRecord.Sustainable_Development_Goals__c}"/>
                                    <ui:inputCheckbox label="Alleviation of your country's disease burden" value="{!v.form.grantRecord.Alleviation_of_your_country_s_disease__c}"/>
                                    <ui:inputCheckbox label="Alleviation of the disease burden of the respective State(s) (in which the host institution is housed in India) " value="{!v.form.grantRecord.Alleviation_of_the_disease_burden__c}"/>
                                    <ui:inputCheckbox label="Contribution to the host institution(s)" value="{!v.form.grantRecord.Contribution_to_the_host_institution__c}"/>
                                
                                    <aura:if isTrue="{!or(or(v.form.grantRecord.Sustainable_Development_Goals__c,v.form.grantRecord.Alleviation_of_your_country_s_disease__c),or(v.form.grantRecord.Alleviation_of_the_disease_burden__c,v.form.grantRecord.Contribution_to_the_host_institution__c))}">
                                        <div class="slds-col slds-size_1-of-1 slds-large-size_12-of-12">
                                            <br/><br/>
                                            <div class="slds-progress__item_content slds-grid slds-grid_align-spread QuestionClass"></div>
                                            <br/>
                                            <lightning:textarea onchange="{!c.validateTextArea}" name="" label="" value="{!v.form.grantRecord.SDGs_Description__c}"/>    
                                            
                                        </div>
                                    </aura:if>
                                    
                                
                                </aura:if>
                                <aura:if isTrue="{!v.defaultMode=='read'}">
                                    <ui:inputCheckbox label="Sustainable Development Goals" value="{!v.form.grantRecord.Sustainable_Development_Goals__c}" disabled="true"/>
                                    <ui:inputCheckbox label="Alleviation of your country's disease burden " value="{!v.form.grantRecord.Alleviation_of_your_country_s_disease__c}" disabled="true"/>
                                    <ui:inputCheckbox label="Alleviation of the disease burden of the respective State(s) (in which the host institution is housed in India) " value="{!v.form.grantRecord.Alleviation_of_the_disease_burden__c}" disabled="true"/>
                                    <ui:inputCheckbox label="Contribution to the host institution(s)" value="{!v.form.grantRecord.Contribution_to_the_host_institution__c}" disabled="true"/>
                                	<br/>
                                    <aura:if isTrue="{!or(or(v.form.grantRecord.Sustainable_Development_Goals__c,v.form.grantRecord.Alleviation_of_your_country_s_disease__c),or(v.form.grantRecord.Alleviation_of_the_disease_burden__c,v.form.grantRecord.Contribution_to_the_host_institution__c))}">
                                    {!v.form.grantRecord.SDGs_Description__c}
                                    </aura:if>
                                </aura:if>
                            </div>
                        </div>
                        <div class="slds-col slds-size_1-of-1 slds-large-size_12-of-12" style="text-align: right;">
                            <aura:if isTrue="{!v.defaultMode!='read'}">
                                <br/>
                                <ul class="slds-button-group-row">
                                    <li class="slds-button-group-item">
                                        <button class="slds-button slds-button_brand" onclick="{!c.save}">Save Draft</button>
                                    </li>
                                    <li class="slds-button-group-item">
                                        <lightning:button variant="brand" label="Save &amp; Previous" title="Save &amp; Previous" value="15" onclick="{! c.save }" />
                                    </li>
                                    <li class="slds-button-group-item">
                                        <button class="slds-button slds-button_brand" onclick="{!c.saveAndRedirect}">Cancel</button>
                                    </li>
                                </ul>
                            </aura:if>
                            <aura:if isTrue="{!v.defaultMode=='read'}">
                                <br/>
                                <ul class="slds-button-group-row">
                                    <li class="slds-button-group-item">
                                        <lightning:button variant="brand" label="Previous" title="Previous" value="15" onclick="{! c.next }" />
                                    </li>
                                </ul>
                            </aura:if>
                        </div>
                    </div>
                    
                </div>
            </div> 
        </div>
        <!-- body end-->
    </div>
</aura:component>