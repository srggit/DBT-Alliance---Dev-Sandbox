<aura:component controller="TSGApplicationFormController" implements="force:appHostable,flexipage:availableForAllPageTypes,flexipage:availableForRecordHome,force:hasRecordId,forceCommunity:availableForAllPageTypes,force:lightningquickactionwithoutheader" access="global" >
    <!-- create 2 aura handler with waiting and donewaiting events--> 
    <aura:handler event="aura:waiting" action="{!c.showSpinner}"/>
    <aura:handler event="aura:doneWaiting" action="{!c.hideSpinner}"/>
    <!--create a component attributs -->
    <aura:attribute name="Spinner" type="boolean" default="false"/>
    <aura:attribute name="schemeId" type="String"/>
    <!-- attributes -->
    <aura:attribute name="startDateFrom" type="String" default="2021-05-19"/>
    <aura:handler name="init" value="{!this}" action="{!c.doInit}"/>
    <aura:method name="initializeTSGForm" action="{!c.initTSG}" />
    <aura:attribute name="initLayout" type="boolean" default="false"/>
    <aura:attribute name="recordTypeId" type="String"/>
    <aura:attribute name="defaultMode" type="String" default="read"/>
    <aura:attribute name="steps" type="List"/>
    <aura:attribute name="showAddInvestigator" type="boolean" default="false"/>
    <aura:attribute name="showAddInvestigatorPH" type="boolean" default="false"/>
    <aura:attribute name="showAddPost" type="boolean" default="false"/>
    <aura:attribute name="showAddEducation" type="boolean" default="false"/>
    <aura:attribute name="showAddYear" type="boolean" default="false"/>
    <aura:attribute name="showAddSupportStaff" type="boolean" default="false"/>
    <aura:attribute name="showAddMC" type="boolean" default="false"/>
    <aura:attribute name="showAddEQ" type="boolean" default="false"/>
    <aura:attribute name="showAddAC" type="boolean" default="false"/>
    <aura:attribute name="showAddANI" type="boolean" default="false"/>
    <aura:attribute name="showAddANIC" type="boolean" default="false"/>
    <aura:attribute name="showAddMIS" type="boolean" default="false"/>
    <aura:attribute name="showAddTC" type="boolean" default="false"/>
    <aura:attribute name="showAddINS" type="boolean" default="false"/>
    <aura:attribute name="showAddInstitution" type="boolean" default="false"/>
    <aura:attribute name="investigatorList" type="List" default="[]"/>
    <aura:attribute name="currentStep" type="String" default="step1"/>
    <aura:attribute name="showAddInvestigatorId" type="String"/>
    <aura:attribute name="showAddInvestigatorPHId" type="String"/>
    <aura:attribute name="showAddPostId" type="String"/>
    <aura:attribute name="showAddODId" type="String"/>
    <aura:attribute name="showAddOD" type="String"/>
    <aura:attribute name="showAddOFSId" type="String"/>
    <aura:attribute name="showAddOFS" type="String"/>
    <aura:attribute name="showAddFOId" type="String"/>
    <aura:attribute name="showAddFO" type="String"/>
    <aura:attribute name="showAddEducationId" type="String"/>
    <aura:attribute name="showAddYearId" type="String"/>
    <aura:attribute name="showAddSupportStaffId" type="String"/>
    <aura:attribute name="showAddMCId" type="String"/>
    <aura:attribute name="showAddRAR" type="String"/>
    <aura:attribute name="showAddRARId" type="String"/>
    <aura:attribute name="showAddINSId" type="boolean" default="false"/>
    <aura:attribute name="showAddEQId" type="String"/>
    <aura:attribute name="showAddACId" type="String"/>
    <aura:attribute name="showAddANIId" type="String"/>
    <aura:attribute name="showAddANICId" type="String"/>
    <aura:attribute name="showAddMISId" type="String"/>
    <aura:attribute name="showAddTCId" type="String"/>
    <aura:attribute name="investigatorRecord" type="Investigator__c" default="{ 'sobjectType': 'Investigator__c' }"/>
    <aura:attribute name="form" type="object"/>
    <aura:attribute name="isError" type="boolean" default="false"/>
    <aura:attribute name="isSkipValidation" type="boolean" default="false"/>
    <aura:attribute name="errorMsgList" type="List" default="[]"/>
    <!-- header -->
    <aura:handler event="c:aeEvent" action="{!c.handleApplicationEvent}"/>
    
    <aura:if isTrue="{!v.Spinner}">
        <div aura:id="spinnerId" class="slds-spinner_container">
            <div class="slds-spinner--brand  slds-spinner slds-spinner--large slds-is-relative" role="alert">
                <span class="slds-assistive-text">Loading</span>
                <div class="slds-spinner__dot-a"></div>
                <div class="slds-spinner__dot-b"></div>
            </div>
        </div>
    </aura:if>
    
    <div style="background:white;">
        <aura:if isTrue="{!v.defaultMode != 'read'}">
            <div class="slds-page-header">
                <div class="slds-page-header__row">
                    <div class="slds-page-header__col-title">
                        <div class="slds-media">
                            <div class="slds-media__figure">
                                <span class="slds-icon_container slds-icon-standard-opportunity" title="opportunity">
                                    <lightning:icon iconName="standard:account" alternativeText="Account" title="Account" />
                                </span>
                            </div>
                            <div class="slds-media__body">
                                <div class="slds-page-header__name">
                                    <div class="slds-page-header__name-title">
                                        <h1>
                                            <span class="slds-page-header__title  " title="{!v.form.grantRecord.RecordType.Name}">{!v.form.grantRecord.RecordType.Name}</span>
                                        </h1>
                                    </div>
                                </div>
                                <p class="slds-page-header__name-meta">Application Form</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </aura:if>
        <!-- header end -->
        <!-- body start-->
        <div class="slds-p-around_x-small ">
            <div class="slds-grid slds-wrap">
                <div class="slds-col slds-size_1-of-1 slds-large-size_12-of-12"> 
                    <div class="slds-grid slds-wrap">
                        <div class="slds-col slds-size_1-of-1 slds-large-size_12-of-12">
                            <aura:if isTrue="{!v.currentStep != ''}">
                                <lightning:progressIndicator currentStep="{!v.currentStep}" type="path" variant="base">
                                    <aura:iteration items="{! v.steps }" var="step">
                                        <lightning:progressStep label="{! step.label }" title="{! step.label }" value="{! step.value }" onclick="{!c.handleStepBlur}"/>
                                    </aura:iteration>
                                </lightning:progressIndicator>
                            </aura:if>
                        </div>
                    </div>
                </div>
                <div class="slds-col slds-size_1-of-1 slds-large-size_12-of-12">
                    <div class="{!v.isError ? 'slds-show' : 'slds-hide'}">
                        <br/>
                        <ul class="slds-dropdown__list" role="menu">
                            <aura:iteration items="{! v.errorMsgList }" var="error">
                                <li class="slds-dropdown__item" role="presentation">
                                    <a class="slds-has-error" href="javascript:void(0);" role="menuitem" tabindex="-1">
                                        <span class=" " title="Error Item">
                                            <span class="slds-m-horizontal_xx-small">
                                                <span class="slds-icon_container slds-icon-utility-error" title="error">
                                                    <span class="slds-assistive-text">{!error}</span>
                                                </span>
                                            </span>
                                            <span>{!error}</span>
                                        </span>
                                    </a>
                                </li>
                            </aura:iteration>
                        </ul>
                    </div>
                </div>
                <div class="slds-col slds-size_1-of-1 slds-large-size_12-of-12">
                    <div class="{!v.showAddINS ? 'slds-show' : 'slds-hide'}">
                        <section role="dialog" tabindex="-1" aria-labelledby="modal-heading-01" aria-modal="true" aria-describedby="modal-content-id-1" class="slds-modal slds-fade-in-open">
                            <div class="slds-modal__container">
                                <header class="slds-modal__header">
                                    <h2 id="modal-heading-01" class="slds-modal__title slds-hyphenate">Add Institution</h2>
                                </header>
                                <div class="slds-modal__content slds-p-around_medium" id="modal-content-id-1" style="height:400px;">
                                    <lightning:recordEditForm recordId = "{!v.showAddINSId}"
                                                              objectApiName="Institution__c"
                                                              onsuccess="{!c.handleCreateRecord}">
                                        <lightning:messages />
                                        <lightning:inputField aura:id="grantIdInstitution" fieldName="Grants__c" class="slds-hide"/>
                                        <aura:if isTrue="{!v.showAddINS}">
                                            <aura:if isTrue="{! !v.showAddInstitution}">
                                                <lightning:inputField fieldName="Institution__c"/> <a onclick="{!c.createInstitution}">Create New Institution </a><br/>
                                                <lightning:inputField fieldName="Type__c"/>
                                                <lightning:button name="v.showAddINS" class="slds-m-top_small" type="submit" label="Add" />
                                            </aura:if>
                                        </aura:if>
                                    </lightning:recordEditForm>
                                    <aura:if isTrue="{!v.showAddInstitution}">
                                        <lightning:recordEditForm
                                                                  objectApiName="Account"
                                                                  onsuccess="{!c.handleCreateInstitutionRecord}">
                                            <lightning:messages />
                                            <lightning:inputField fieldName="Name"/>
                                            <lightning:inputField fieldName="Department__c"/>
                                            <lightning:inputField fieldName="Address__c"/>
                                            <lightning:inputField fieldName="City__c"/>
                                            <lightning:inputField fieldName="Country__c"/>
                                            <lightning:inputField fieldName="Pincode__c"/>
                                            <lightning:inputField fieldName="Institution_Categories__c"/>
                                            <lightning:button class="" type="submit" label="Add Institution" />
                                            <lightning:button variant="neutral" label="Back" title="Back" onclick="{! c.handleCreateInstitutionRecord }" />
                                        </lightning:recordEditForm>
                                        
                                    </aura:if>
                                </div>
                                <footer class="slds-modal__footer">
                                    <lightning:button variant="neutral" label="Cancel" title="Cancel" name="v.showAddINS" onclick="{! c.closeModal }" />
                                </footer>
                            </div>
                        </section>
                        <div class="slds-backdrop slds-backdrop_open"></div>
                    </div>
                    <div class="{!v.showAddOD ? 'slds-show' : 'slds-hide'}">
                        <section role="dialog" tabindex="-1" aria-labelledby="modal-heading-01" aria-modal="true" aria-describedby="modal-content-id-1" class="slds-modal slds-fade-in-open">
                            <div class="slds-modal__container">
                                <header class="slds-modal__header">
                                    <h2 id="modal-heading-01" class="slds-modal__title slds-hyphenate">Add Other Document</h2>
                                </header>
                                <div class="slds-modal__content slds-p-around_medium" id="modal-content-id-1">
                                    <lightning:recordEditForm recordId = "{!v.showAddODId}"
                                                              objectApiName="Other_Document__c"
                                                              onsuccess="{!c.handleCreateRecord}">
                                        <lightning:messages />
                                        <lightning:inputField aura:id="grantIdod" fieldName="Grants__c" class="slds-hide"/>
                                        <aura:if isTrue="{!v.showAddOD}">
                                            <lightning:inputField fieldName="Subject__c"/>
                                            <lightning:inputField fieldName="Description__c"/>
                                            <lightning:button name="v.showAddOD" class="slds-m-top_small" type="submit" label="Add Other Document" />
                                        </aura:if>
                                    </lightning:recordEditForm>
                                </div>
                                <footer class="slds-modal__footer">
                                    <lightning:button variant="neutral" label="Cancel" title="Cancel" name="v.showAddOD" onclick="{! c.closeModal }" />
                                </footer>
                            </div>
                        </section>
                        <div class="slds-backdrop slds-backdrop_open"></div>
                    </div>
                    <div class="{!v.showAddOFS ? 'slds-show' : 'slds-hide'}">
                        <section role="dialog" tabindex="-1" aria-labelledby="modal-heading-01" aria-modal="true" aria-describedby="modal-content-id-1" class="slds-modal slds-fade-in-open">
                            <div class="slds-modal__container">
                                <header class="slds-modal__header">
                                    <h2 id="modal-heading-01" class="slds-modal__title slds-hyphenate">Add Other Financial Support</h2>
                                </header>
                                <div class="slds-modal__content slds-p-around_medium" id="modal-content-id-1">
                                    <lightning:recordEditForm recordId = "{!v.showAddOFSId}"
                                                              objectApiName="Other_Financial_Support__c"
                                                              onsuccess="{!c.handleCreateRecord}">
                                        <lightning:messages />
                                        <lightning:inputField aura:id="invIdofs" fieldName="Investigator__c" class="slds-hide"/>
                                        <aura:if isTrue="{!v.showAddOFS}">
                                            <lightning:inputField fieldName="Name_of_the_funder__c"/>
                                            <lightning:inputField fieldName="Name_s_of_recipient__c"/>
                                            <lightning:inputField fieldName="Title_of_the_project__c"/>
                                            <lightning:inputField fieldName="Start_Date__c"/>
                                            <lightning:inputField fieldName="End_Date__c"/>
                                            <lightning:inputField fieldName="Awarded_Budget_with_currencies__c"/>
                                            <lightning:inputField fieldName="Your_role_in_the_project__c"/>
                                            <lightning:button name="v.showAddOFS" class="slds-m-top_small" type="submit" label="Add Other Financial Support" />
                                        </aura:if>
                                    </lightning:recordEditForm>
                                </div>
                                <footer class="slds-modal__footer">
                                    <lightning:button variant="neutral" label="Cancel" title="Cancel" name="v.showAddOFS" onclick="{! c.closeModal }" />
                                </footer>
                            </div>
                        </section>
                        <div class="slds-backdrop slds-backdrop_open"></div>
                    </div>
                    <div class="{!v.showAddFO ? 'slds-show' : 'slds-hide'}">
                        <section role="dialog" tabindex="-1" aria-labelledby="modal-heading-01" aria-modal="true" aria-describedby="modal-content-id-1" class="slds-modal slds-fade-in-open">
                            <div class="slds-modal__container">
                                <header class="slds-modal__header">
                                    <h2 id="modal-heading-01" class="slds-modal__title slds-hyphenate">Add Funding Organisation</h2>
                                </header>
                                <div class="slds-modal__content slds-p-around_medium" id="modal-content-id-1">
                                    <lightning:recordEditForm recordId = "{!v.showAddFOId}"
                                                              objectApiName="Funding_Organisation__c"
                                                              onsuccess="{!c.handleCreateRecord}">
                                        <lightning:messages />
                                        <lightning:inputField aura:id="invIdfo" fieldName="Investigator__c" class="slds-hide"/>
                                        <aura:if isTrue="{!v.showAddFO}">
                                            <lightning:inputField fieldName="Name_of_the_funding_organisation__c"/>
                                            <lightning:inputField fieldName="Expected_decision_date__c"/>
                                            <lightning:inputField fieldName="Brief_summary_under_200_words__c"/>
                                            <lightning:button name="v.showAddFO" class="slds-m-top_small" type="submit" label="Add Funding Organisation" />
                                        </aura:if>
                                    </lightning:recordEditForm>
                                </div>
                                <footer class="slds-modal__footer">
                                    <lightning:button variant="neutral" label="Cancel" title="Cancel" name="v.showAddFO" onclick="{! c.closeModal }" />
                                </footer>
                            </div>
                        </section>
                        <div class="slds-backdrop slds-backdrop_open"></div>
                    </div>
                    <div class="{!v.showAddEQ ? 'slds-show' : 'slds-hide'}">
                        <section role="dialog" tabindex="-1" aria-labelledby="modal-heading-01" aria-modal="true" aria-describedby="modal-content-id-1" class="slds-modal slds-fade-in-open">
                            <div class="slds-modal__container">
                                <header class="slds-modal__header">
                                    <h2 id="modal-heading-01" class="slds-modal__title slds-hyphenate">Add Equipment</h2>
                                </header>
                                <div class="slds-modal__content slds-p-around_medium" id="modal-content-id-1">
                                    <div class="slds-grid slds-wrap">
                                        
                                        <div class="slds-col slds-size_1-of-1 slds-large-size_12-of-12">
                                            <lightning:recordEditForm recordId="{!v.showAddEQId}"
                                                                      objectApiName="Equipments__c"
                                                                      onsuccess="{!c.handleCreateRecord}">
                                                <lightning:messages />
                                                <lightning:inputField aura:id="budgetIdeq" fieldName="Budget__c" class="slds-hide"/>
                                                <aura:if isTrue="{!v.showAddEQ}">
                                                    <lightning:inputField fieldName="Type_of_Equipment__c"/>
                                                    <lightning:inputField fieldName="Number_of_items__c"/>
                                                    <lightning:inputField fieldName="Cost_per_item__c"/>
                                                    <lightning:inputField fieldName="Cost_of_maintenance_contract_per_year__c"/>
                                                    <lightning:inputField fieldName="Contribution_from_other_sources__c"/>
                                                    <lightning:inputField fieldName="Duration_of_Maintenance__c"/>
                                                    <lightning:button name="v.showAddEQ" class="slds-m-top_small" type="submit" label="Add Equipment" />
                                                </aura:if>
                                            </lightning:recordEditForm>
                                        </div>
                                        
                                    </div>
                                </div>
                                
                                <footer class="slds-modal__footer">
                                    <lightning:button variant="neutral" name="v.showAddEQ" label="Cancel" title="Cancel" onclick="{! c.closeModal }" />
                                </footer>
                            </div>
                        </section>
                        <div class="slds-backdrop slds-backdrop_open"></div>
                    </div>
                    <div class="{!v.showAddANI ? 'slds-show' : 'slds-hide'}">
                        <section role="dialog" tabindex="-1" aria-labelledby="modal-heading-01" aria-modal="true" aria-describedby="modal-content-id-1" class="slds-modal slds-fade-in-open">
                            <div class="slds-modal__container">
                                <header class="slds-modal__header">
                                    <h2 id="modal-heading-01" class="slds-modal__title slds-hyphenate">Add Animal</h2>
                                </header>
                                <div class="slds-modal__content slds-p-around_medium" id="modal-content-id-1">
                                    <div class="slds-grid slds-wrap">
                                        
                                        <div class="slds-col slds-size_1-of-1 slds-large-size_12-of-12">
                                            <lightning:recordEditForm recordId="{!v.showAddANIId}"
                                                                      objectApiName="Animals__c"
                                                                      onsuccess="{!c.handleCreateRecord}">
                                                <lightning:messages />
                                                <lightning:inputField aura:id="budgetIdani" fieldName="Budget__c" class="slds-hide"/>
                                                <aura:if isTrue="{!v.showAddANI}">
                                                    <lightning:inputField fieldName="Animal_species__c"/>
                                                    <lightning:inputField fieldName="Total_number_to_be_purchased__c"/>
                                                    <lightning:inputField fieldName="Total_maintenance_and_procedure_cost__c"/>
                                                    <lightning:inputField fieldName="Total_purchase_cost__c"/>
                                                    <lightning:button name="v.showAddANI" class="slds-m-top_small" type="submit" label="Add Animal" />
                                                </aura:if>
                                            </lightning:recordEditForm>
                                        </div>
                                        
                                    </div>
                                </div>
                                
                                <footer class="slds-modal__footer">
                                    <lightning:button variant="neutral" name="v.showAddANI" label="Cancel" title="Cancel" onclick="{! c.closeModal }" />
                                </footer>
                            </div>
                        </section>
                        <div class="slds-backdrop slds-backdrop_open"></div>
                    </div>
                    <div class="{!v.showAddANIC ? 'slds-show' : 'slds-hide'}">
                        <section role="dialog" tabindex="-1" aria-labelledby="modal-heading-01" aria-modal="true" aria-describedby="modal-content-id-1" class="slds-modal slds-fade-in-open">
                            <div class="slds-modal__container">
                                <header class="slds-modal__header">
                                    <h2 id="modal-heading-01" class="slds-modal__title slds-hyphenate">Add Animal Associated Cost</h2>
                                </header>
                                <div class="slds-modal__content slds-p-around_medium" id="modal-content-id-1">
                                    <div class="slds-grid slds-wrap">
                                        
                                        <div class="slds-col slds-size_1-of-1 slds-large-size_12-of-12">
                                            <lightning:recordEditForm recordId="{!v.showAddANICId}"
                                                                      objectApiName="Animal_Associated_costs__c"
                                                                      onsuccess="{!c.handleCreateRecord}">
                                                <lightning:messages />
                                                <lightning:inputField aura:id="budgetIdanic" fieldName="Budget__c" class="slds-hide"/>
                                                <aura:if isTrue="{!v.showAddANIC}">
                                                    <lightning:inputField fieldName="Description__c"/>
                                                    <lightning:inputField fieldName="Total__c"/>
                                                    <lightning:button name="v.showAddANIC" class="slds-m-top_small" type="submit" label="Add Animal Associated Cost" />
                                                </aura:if>
                                            </lightning:recordEditForm>
                                        </div>
                                        
                                    </div>
                                </div>
                                
                                <footer class="slds-modal__footer">
                                    <lightning:button variant="neutral" name="v.showAddANIC" label="Cancel" title="Cancel" onclick="{! c.closeModal }" />
                                </footer>
                            </div>
                        </section>
                        <div class="slds-backdrop slds-backdrop_open"></div>
                    </div>
                    <div class="{!v.showAddAC ? 'slds-show' : 'slds-hide'}">
                        <section role="dialog" tabindex="-1" aria-labelledby="modal-heading-01" aria-modal="true" aria-describedby="modal-content-id-1" class="slds-modal slds-fade-in-open">
                            <div class="slds-modal__container">
                                <header class="slds-modal__header">
                                    <h2 id="modal-heading-01" class="slds-modal__title slds-hyphenate">Add Access Charges</h2>
                                </header>
                                <div class="slds-modal__content slds-p-around_medium" id="modal-content-id-1">
                                    <div class="slds-grid slds-wrap">
                                        
                                        <div class="slds-col slds-size_1-of-1 slds-large-size_12-of-12">
                                            <lightning:recordEditForm recordId="{!v.showAddACId}"
                                                                      objectApiName="Access_charges__c"
                                                                      onsuccess="{!c.handleCreateRecord}">
                                                <lightning:messages />
                                                <lightning:inputField aura:id="budgetIdac" fieldName="Budget__c" class="slds-hide"/>
                                                <aura:if isTrue="{!v.showAddAC}">
                                                    <abbr lightning-input_input="" title="required" class="slds-required">*</abbr>Details of equipment/facility with location
                                                    <div class="labelHide"><lightning:inputField fieldName="Access_Charge_Name__c"/></div>
                                                    <lightning:inputField fieldName="Specify_access__c"/>
                                                    <lightning:inputField fieldName="Place__c"/>
                                                    <lightning:inputField fieldName="Number_of_Units__c"/>
                                                    <lightning:inputField fieldName="Access_Charges_Per_Unit__c"/>
                                                    <lightning:button name="v.showAddAC" class="slds-m-top_small" type="submit" label="Add Access Charge" />
                                                </aura:if>
                                            </lightning:recordEditForm>
                                        </div>
                                        
                                    </div>
                                </div>
                                
                                <footer class="slds-modal__footer">
                                    <lightning:button variant="neutral" name="v.showAddAC" label="Cancel" title="Cancel" onclick="{! c.closeModal }" />
                                </footer>
                            </div>
                        </section>
                        <div class="slds-backdrop slds-backdrop_open"></div>
                    </div>
                    <div class="{!v.showAddMC ? 'slds-show' : 'slds-hide'}">
                        <section role="dialog" tabindex="-1" aria-labelledby="modal-heading-01" aria-modal="true" aria-describedby="modal-content-id-1" class="slds-modal slds-fade-in-open">
                            <div class="slds-modal__container">
                                <header class="slds-modal__header">
                                    <h2 id="modal-heading-01" class="slds-modal__title slds-hyphenate">Add Materials and Consumables</h2>
                                </header>
                                <div class="slds-modal__content slds-p-around_medium" id="modal-content-id-1">
                                    <div class="slds-grid slds-wrap">
                                        
                                        <div class="slds-col slds-size_1-of-1 slds-large-size_12-of-12">
                                            <lightning:recordEditForm recordId="{!v.showAddMCId}"
                                                                      objectApiName="Materials_and_Consumables__c"
                                                                      onsuccess="{!c.handleCreateRecord}">
                                                <lightning:messages />
