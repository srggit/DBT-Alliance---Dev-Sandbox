                                            </th>
                                            <aura:iteration var="investigator" items="{!v.form.investigatorRecordList}" indexVar="indx">
                                                <th class="" scope="col">
                                                    <div class=" " title=""><lightning:input type="number" name="" step="0.01" value="{! investigator.investigatorRecord.Hours_per_week_to_be_spent_on_Research__c }" disabled="true"/></div>
                                                </th>
                                            </aura:iteration>
                                        </tr>
                                        <tr class="slds-line-height_reset">
                                            <th class="nowrap" scope="col" width="30">
                                                <div class=" " title="Number of hours per week to be spent on active grants/fellowships/projects other than this proposed project">(D) Number of hours per week to be spent on <br/>active grants/fellowships/projects other than this proposed project</div>
                                            </th>
                                            <aura:iteration var="investigator" items="{!v.form.investigatorRecordList}" indexVar="indx">
                                                <th class="" scope="col">
                                                    <div class=" " title="">
                                                        <aura:if isTrue="{!v.defaultMode!='read'}">
                                                            <lightning:input type="number" name="" step="0.01" value="{! investigator.investigatorRecord.Hours_per_week_on_Active_Grants_Projects__c  }" onchange="{!c.handleTimeClick}"/>
                                                        </aura:if>
                                                        <aura:if isTrue="{!v.defaultMode=='read'}">
                                                            {! investigator.investigatorRecord.Hours_per_week_on_Active_Grants_Projects__c }
