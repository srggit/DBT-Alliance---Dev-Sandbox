                                            <lightning:inputField fieldName="Address__c"/>
                                            <lightning:inputField fieldName="City__c"/>
                                            <lightning:inputField fieldName="Country__c"/>
                                            <lightning:inputField fieldName="Pincode__c"/>
                                            <lightning:inputField fieldName="Institution_Categories__c"/>
