                                    </li>
                                    <li class="slds-button-group-item">
                                        <lightning:button variant="brand" label="Save &amp; Next" title="Save &amp; Next" value="4" onclick="{! c.save }" />
                                    </li>
                                    <li class="slds-button-group-item">
                                        <button class="slds-button slds-button_brand" onclick="{!c.saveAndRedirect}">Cancel</button>
                                    </li>
                                </ul>
                            </aura:if>
                            <aura:if isTrue="{!v.defaultMode=='read'}">
                                <br/>
                                <ul class="slds-button-group-row">
                                    <li class="slds-button-group-item">
                                        <lightning:button variant="brand" label="Previous" title="Previous" value="2" onclick="{! c.next }" />
                                    </li>
                                    <li class="slds-button-group-item">
                                        <lightning:button variant="brand" label="Next" title="Next" value="4" onclick="{! c.next }" />
                                    </li>
                                </ul>
                            </aura:if>
                        </div>
                    </div>
                    <div class="{!v.currentStep == 'step4'? 'slds-show' : 'slds-hide'}">
                        <br/><br/><div class="slds-grid slds-wrap tab2">
                        <div class="slds-col slds-size_1-of-1 slds-large-size_8-of-12"> 
                            <div class="slds-page-header__name">
                                <div class="slds-page-header__name-title">
                                    <h1>
                                        <span class="slds-page-header__title  " title="Budget (with justification)"><i>
                                            <aura:if isTrue="{! !v.form.isCRC}"><i>4. Budget (with justification)</i></aura:if>
                                            <aura:if isTrue="{! v.form.isCRC}"><i>5. Budget (with justification)</i></aura:if>
                                            </i></span>
                                    </h1>
                                </div>
                            </div>
                        </div>
                        <div class="slds-col slds-size_1-of-1 slds-large-size_4-of-12" style="text-align: right;">
                            <aura:if isTrue="{!v.defaultMode!='read'}">
                                <ul class="slds-button-group-row">
                                    <li class="slds-button-group-item">
                                        <button class="slds-button slds-button_brand" onclick="{!c.save}">Save Draft</button>
                                    </li>
                                    <li class="slds-button-group-item">
                                        <lightning:button variant="brand" label="Save &amp; Previous" title="Save &amp; Previous" value="3" onclick="{! c.save }" />
