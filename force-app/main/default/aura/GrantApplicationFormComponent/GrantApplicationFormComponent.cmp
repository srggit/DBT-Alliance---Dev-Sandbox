                                <table class="slds-table slds-table_cell-buffer slds-table_bordered">
                                    <thead>
                                        
                                        <tr class="slds-line-height_reset">
                                            <th class="nowrap" scope="col" width="30">
                                                <div class=" " title="">Description</div>
                                            </th>
                                            <aura:iteration var="investigator" items="{!v.form.investigatorRecordList}" indexVar="indx">
                                                <th class="" scope="col">
                                                    <div class=" " title="">{! investigator.investigatorRecord.Full_Name__c }  &nbsp; {! investigator.code} </div>
                                                </th>
                                            </aura:iteration>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr class="slds-line-height_reset">
                                            <th class="nowrap" scope="col" width="30">
                                                <div class=" " title="Number of total working hours per week">(A) Number of total working hours per week (B+C)</div>
                                            </th>
                                            <aura:iteration var="investigator" items="{!v.form.investigatorRecordList}" indexVar="indx">
                                                <th class="" scope="col">
                                                    <div class=" " title=""><lightning:input type="number" name="" step="0.01" value="{! investigator.investigatorRecord.Number_of_total_working_hours_per_week__c }" disabled="true"/></div>
                                                </th>
                                            </aura:iteration>
                                        </tr>
                                        <tr class="slds-line-height_reset">
                                            <th class="nowrap" scope="col" width="30">
