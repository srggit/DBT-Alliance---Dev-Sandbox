                                            </th>
                                            <th class="" scope="col">
                                                <div class=" " title="{!v.form.budget.IAContributionAmount }"><ui:outputCurrency value="{!v.form.budget.IAContributionAmount }"/></div>
                                            </th>
                                        </tr>
                                    </tbody>
                                    <thead>
                                        <tr class="slds-line-height_reset">
                                            <th class="" scope="col">
                                                <div class=" " title="(A)">(A)</div>
