                                </table>
                            </div>
                            <div class="slds-col slds-size_1-of-1 slds-large-size_12-of-12">
                                <br/>
                                <div class="slds-progress__item_content slds-grid slds-grid_align-spread QuestionClass">1. Salaries</div>
                            </div>
                            <div class="slds-col slds-size_1-of-1 slds-large-size_12-of-12">
                                <br/>
                                <div class="slds-progress__item_content slds-grid slds-grid_align-spread QuestionClass">(i) *Salaries for PIs: PIs (PI and co-PIs) must hold an academic or research post and have a salary, or the guarantee of a salary, for the duration of the award period. If your academic or research position requires you to get all/part of your salary from extramural funding, please refer to the scheme guidelines and grant costing policies. For this, you must be based at an eligible Indian host institution and your host institution must confirm in writing that your employment contract requires you to raise your salary from extramural funding.  </div>
                                <div class="slds-progress__item_content slds-grid slds-grid_align-spread">Please indicate the salary that is being requested as part of this application. </div>
                            </div>
                            <!--<aura:if isTrue="{!v.defaultMode!='read'}"><div style="text-align:right;"><lightning:button variant="" label="Add Year" name="v.showAddYear" title="Add Year" onclick="{! c.openModal }" /></div></aura:if>-->
                            <!--<div class="slds-col slds-size_1-of-1 slds-large-size_12-of-12">
                                <div class="slds-progress__item_content slds-grid slds-grid_align-spread">(i) *Salaries for PIs: PIs (PI and Co-PIs) must hold an academic or research post and have a salary, or the guarantee of a salary, for the duration of the award period. If your academic or research position requires you to get all/part of your salary from extramural funding, please refer to the scheme guidelines and grants costing policies. For this, you must be based at an eligible Indian host institution and your host institution must confirm in writing that your employment contract requires you to raise your salary from extramural funding.  </div>
                                <div class="slds-progress__item_content slds-grid slds-grid_align-spread">Please indicate the salary that is being requested as part of this application. </div>
                                <div style="text-align:right;"><lightning:button variant="" label="Add Year" title="Add Year" onclick="{! c.openYear }" /></div>
                                <div style="border:1px solid gray; text-align: center;">Amount (INR) </div>
                            </div>-->
                            <div class="slds-col slds-size_1-of-1 slds-large-size_12-of-12">
                                <table class="slds-table slds-table_cell-buffer slds-table_bordered">
                                    <thead>
                                        <tr class="slds-line-height_reset">
                                            <th class="" scope="col">
                                                <div class=" " title="Investigator Name">Investigator Name</div>
                                            </th>
                                            <th class="" scope="col">
                                                <div class=" " title="Year">Year 1</div>
                                            </th>
                                            <th class="" scope="col">
                                                <div class=" " title="Year">Year 2</div>
                                            </th>
                                            <th class="" scope="col">
                                                <div class=" " title="Year">Year 3</div>
                                            </th>
                                            <th class="" scope="col">
                                                <div class=" " title="Year">Year 4</div>
                                            </th>
                                            <th class="" scope="col">
                                                <div class=" " title="Year">Year 5</div>
                                            </th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <aura:iteration var="investigator" items="{!v.form.investigatorRecordList}" indexVar="indx">
                                            <tr class="slds-line-height_reset">
                                                <th class="" scope="col">
                                                    <div class=" " title="{!investigator.investigatorRecord.Full_Name__c}">{!investigator.investigatorRecord.Full_Name__c}</div>
                                                </th>
                                                <th class="" scope="col">
                                                    <aura:if isTrue="{!v.defaultMode!='read'}">
                                                        <lightning:input type="number" name="" label="" value="{!investigator.investigatorRecord.Year_1__c}" formatter="currency" step="0.01" onchange="{!c.handleYearClick}"/>
                                                    </aura:if>
                                                    <aura:if isTrue="{!v.defaultMode=='read'}">
                                                        {!investigator.investigatorRecord.Year_1__c}
                                                    </aura:if> 
                                                </th>
                                                <th class="" scope="col">
                                                    <aura:if isTrue="{!v.defaultMode!='read'}">
                                                        <lightning:input type="number" name="" label="" value="{!investigator.investigatorRecord.Year_2__c}" formatter="currency" step="0.01" onchange="{!c.handleYearClick}"/>
                                                    </aura:if>
                                                    <aura:if isTrue="{!v.defaultMode=='read'}">
                                                        {!investigator.investigatorRecord.Year_2__c}
                                                    </aura:if>
                                                </th>
                                                <th class="" scope="col">
                                                    <aura:if isTrue="{!v.defaultMode!='read'}">
                                                        <lightning:input type="number" name="" label="" value="{!investigator.investigatorRecord.Year_3__c}" formatter="currency" step="0.01" onchange="{!c.handleYearClick}"/>
                                                    </aura:if>
                                                    <aura:if isTrue="{!v.defaultMode=='read'}">
                                                        {!investigator.investigatorRecord.Year_3__c}
                                                    </aura:if>
                                                </th>
                                                <th class="" scope="col">
                                                    <aura:if isTrue="{!v.defaultMode!='read'}">
                                                        <lightning:input type="number" name="" label="" value="{!investigator.investigatorRecord.Year_4__c}" formatter="currency" step="0.01" onchange="{!c.handleYearClick}"/>
                                                    </aura:if>
                                                    <aura:if isTrue="{!v.defaultMode=='read'}">
                                                        {!investigator.investigatorRecord.Year_4__c}
                                                    </aura:if>
                                                </th>
                                                <th class="" scope="col">
                                                    <aura:if isTrue="{!v.defaultMode!='read'}">
                                                        <lightning:input type="number" name="" label="" value="{!investigator.investigatorRecord.Year_5__c}" formatter="currency" step="0.01" onchange="{!c.handleYearClick}"/>
                                                    </aura:if>
                                                    <aura:if isTrue="{!v.defaultMode=='read'}">
                                                        {!investigator.investigatorRecord.Year_5__c}
                                                    </aura:if>
                                                </th>
                                            </tr>
                                        </aura:iteration>
                                    </tbody>
                                </table>
                                <table class="slds-table slds-table_cell-buffer slds-table_bordered">
                                    <thead>
                                        <tr class="slds-line-height_reset">
                                            <th class="" scope="col">
                                                <div class=" " title="Total cost requested under PI salary head">Total cost requested under PI salary head</div>
                                            </th>
                                            <th class="" scope="col">
                                                <div class=" " title="{!v.form.totalYearAmount }"><ui:outputCurrency value="{!v.form.totalYearAmount }"/></div>
                                            </th>
                                        </tr>
                                    </thead>
                                </table>
                            </div>
                        </div>
                        <div class="slds-col slds-size_1-of-1 slds-large-size_12-of-12">
                            <div class="slds-progress__item_content slds-grid slds-grid_align-spread QuestionClass">Justification (Limit 400 words)</div>
                            <aura:if isTrue="{!v.defaultMode!='read'}">
                                <lightning:textarea class="400" name="" label="" value="{!v.form.budget.budgetRecord.Salaries_for_PIs_Justification__c}" onchange="{!c.validateTextArea}"/>
                            </aura:if>
                            <aura:if isTrue="{!v.defaultMode=='read'}">
                                {!v.form.budget.budgetRecord.Salaries_for_PIs_Justification__c}
                            </aura:if>
                        </div>
                        
                        <div class="slds-col slds-size_1-of-1 slds-large-size_12-of-12">
                            <br/>
                            <div class="slds-progress__item_content slds-grid slds-grid_align-spread QuestionClass">2. Support Staff and their Salary Justification</div>
                        </div>
                        <div class="slds-col slds-size_1-of-1 slds-large-size_12-of-12">
                            <div class="">Support staff category: Research assistants, technicians, PhD students, junior research fellows, senior research fellows, research associates, senior residents, field workers, nurses etc. Salaries for support staff should be in line with the recent <a href="https://dst.gov.in/sites/default/files/OM-Scientific_Technical%20Manpower-Guidelines%20and%20emoluments.pdf" target="_blank">Government of India guidelines</a>. <aura:if isTrue="{!v.defaultMode!='read'}"><div style="text-align:right;"><lightning:button variant="" label="Add Support Staff" value="{! v.form.budget.budgetRecord.Id}" name="v.showAddSupportStaff" class="budgetIdsf"   title="Add Support Staff" onclick="{! c.openModal }" /></div></aura:if></div>
                        </div>
                        <div class="slds-col slds-size_1-of-1 slds-large-size_12-of-12 tableScroll">
                            
                            <table class="slds-table slds-table_cell-buffer slds-table_bordered">
                                <thead>
                                    <tr class="slds-line-height_reset">
                                        <th class="nowrap" scope="col">
                                            <div class=" " title="">Staff category</div>
                                        </th>
                                        <th class="nowrap" scope="col">
                                            <div class=" " title="Number of positions">Number of positions</div>
                                        </th>
                                        <th class="nowrap" scope="col">
                                            <div class=" " title="Location/organisation">Location/organisation</div>
                                        </th>
                                        <th class="nowrap" scope="col">
                                            <div class=" " title="Monthly Salary">Monthly Salary</div>
                                        </th>
                                        <th class="nowrap" scope="col">
                                            <div class=" " title="Period on project (months)">Period on project (months)</div>
                                        </th>
                                        <th class="nowrap" scope="col">
                                            <div class=" " title="% time">% time</div>
                                        </th>
                                        <th class="nowrap" scope="col">
                                            <div class=" " title="Total cost requested on grant for entire duration ">Total cost requested on <br/>grant for entire duration </div>
                                        </th>
                                        <aura:if isTrue="{!v.defaultMode!='read'}">
                                            <th class="nowrap" scope="col">
                                                <div class=" " title="Action">Action </div>
                                            </th>
                                        </aura:if>
                                    </tr>
                                </thead>
                                <tbody>
                                    <aura:iteration var="sf" items="{!v.form.budget.supportStaffList}" indexVar="indx">
                                        <tr>
                                            <th class="nowrap" scope="col">
                                                <div class=" " title="{!sf.Staff_Category__c}">{!sf.Staff_Category__c}</div>
                                            </th>
                                            <th class="nowrap" scope="col">
                                                <div class=" " title="{!sf.Number_of_Positions__c}">{!sf.Number_of_Positions__c}</div>
                                            </th>
                                            <th class="nowrap" scope="col">
                                                <div class=" " title="{!sf.Organisation__r.Name}">{!sf.Organisation__r.Name}</div> 
                                            </th>
                                            <th class="nowrap" scope="col">
                                                <div class=" " title="{!sf.Salary_Grade__c}">{!sf.Salary_Grade__c}</div>
                                            </th>
                                            <th class="nowrap" scope="col">
                                                <div class=" " title="{!sf.Period_on_Project__c}">{!sf.Period_on_Project__c}</div>
                                            </th>
                                            <th class="nowrap" scope="col">
                                                <div class=" " title="{!sf.Time__c}">{!sf.Time__c}</div>
                                            </th>
                                            <th class="nowrap" scope="col">
                                                <div class=" " title="{!sf.Total__c}"><ui:outputCurrency value="{!sf.Total__c}"/> </div>
                                            </th>
                                            <aura:if isTrue="{!v.defaultMode!='read'}">
                                                <th class="nowrap" scope="col">
                                                    <div class=" "><lightning:button variant="neutral" label="Edit" title="Edit" value="{! sf.Id}" name="v.showAddSupportStaff" onclick="{! c.editRecord }"/>
                                                        <lightning:button variant="neutral" label="Remove" title="Remove" value="{!sf.Id}" onclick="{! c.removeRecord }" /></div>
                                                </th>
                                            </aura:if>
                                        </tr>
                                    </aura:iteration>
                                </tbody>
                                <thead>
                                    <tr>
                                        <th class="" scope="col" colspan="6">
                                            <div class=" " title="Total cost requested under support staff salary head">Total cost requested under support staff salary head</div>
                                        </th>
                                        <th class="" scope="col">
                                            <div class=" " title="{!v.form.budget.totalsfAmount }"><ui:outputCurrency value="{!v.form.budget.totalsfAmount }"/></div>
                                        </th>
                                        <aura:if isTrue="{!v.defaultMode!='read'}"><th class="" scope="col"></th></aura:if>
                                    </tr>
                                </thead>
                            </table>
                        </div>
                        <div class="slds-col slds-size_1-of-1 slds-large-size_12-of-12">
                            <div class="slds-progress__item_content slds-grid slds-grid_align-spread QuestionClass">Support staff justification(Justification for personnel requested, specifying their role and responsibilities; Limit 500 words)</div>
                            <aura:if isTrue="{!v.defaultMode!='read'}">
                                <lightning:textarea class="500" name="" label="" value="{!v.form.budget.budgetRecord.Support_staff_justification__c}" onchange="{!c.validateTextArea}"/>
                            </aura:if>
                            <aura:if isTrue="{!v.defaultMode=='read'}">
                                {!v.form.budget.budgetRecord.Support_staff_justification__c}
                            </aura:if>
                        </div>
                        <br/>
                        <div class="slds-col slds-size_1-of-1 slds-large-size_12-of-12">
                            <br/>
                            <div class="slds-progress__item_content slds-grid slds-grid_align-spread QuestionClass">3. Materials and consumables</div>
                        </div>
                        <aura:if isTrue="{!v.defaultMode!='read'}"><div style="text-align:right;"><lightning:button variant="" label="Add Materials and Consumables" title="Add Materials and Consumables" value="{! v.form.budget.budgetRecord.Id}" name="v.showAddMC" class="budgetIdmc" onclick="{! c.openModal }" /></div></aura:if>
                        <div class="slds-col slds-size_1-of-1 slds-large-size_12-of-12 tableScroll">
                            <table class="slds-table slds-table_cell-buffer slds-table_bordered">
                                <thead>
                                    <tr class="slds-line-height_reset">
                                        <th class="nowrap" scope="col">
                                            <div class=" " title="">Materials and consumables (description of items) <br/>Please add separate entries in the table below </div>
                                        </th>
                                        <th class="nowrap" scope="col">
                                            <div class=" " title="Costs (INR)">Costs (INR)</div>
                                        </th>   
                                        <aura:if isTrue="{!v.defaultMode!='read'}">
                                            <th class="" scope="col">
                                                <div class=" " title="Action">Action </div>
                                            </th>
                                        </aura:if>
                                    </tr>
                                </thead>
                                <tbody>
                                    <aura:iteration var="mc" items="{!v.form.budget.MConsumablesList}" indexVar="indx">
                                        <tr>
                                            <th class="" scope="col">
                                                <div class=" " title="{!mc.Name}">{!mc.Materials_and_Consumables_Name__c}</div>
                                            </th>
                                            <th class="" scope="col">
                                                <div class=" " title="{!mc.Costs__c}"><ui:outputCurrency value="{!mc.Costs__c}"/></div>
                                            </th>
                                            <aura:if isTrue="{!v.defaultMode!='read'}">
                                                <th class="nowrap" scope="col">
                                                    <div class=" ">
                                                        <lightning:button variant="neutral" label="Edit" title="Edit" value="{! mc.Id}" name="v.showAddMC" onclick="{! c.editRecord }"/>
                                                        <lightning:button variant="neutral" label="Remove" title="Remove" value="{!mc.Id}" onclick="{! c.removeRecord }" /></div>
                                                </th>
                                            </aura:if>
                                        </tr>
                                    </aura:iteration>
                                </tbody>
                                <thead>
                                    <tr>
                                        <th class="" scope="col">
                                            <div class=" " title="Total cost requested under materials and consumables head">Total cost requested under materials and consumables head</div>
                                        </th>
                                        <th class="" scope="col">
                                            <div class=" " title="{!v.form.budget.totalmcAmount }"><ui:outputCurrency value="{!v.form.budget.totalmcAmount }"/></div>
                                        </th>
                                        <aura:if isTrue="{!v.defaultMode!='read'}"><th class="" scope="col"></th></aura:if>
                                    </tr>
                                </thead>
                            </table>
                        </div>
                        <div class="slds-col slds-size_1-of-1 slds-large-size_12-of-12">
                            <div class="slds-progress__item_content slds-grid slds-grid_align-spread QuestionClass">Itemised justification for materials and consumables requested (Limit 500 words)</div>
                            <aura:if isTrue="{!v.defaultMode!='read'}">
                                <lightning:textarea class="500" name="" label="" value="{!v.form.budget.budgetRecord.Materials_and_Consumables_Justification__c}" onchange="{!c.validateTextArea}"/>
                            </aura:if>
                            <aura:if isTrue="{!v.defaultMode=='read'}">
                                {!v.form.budget.budgetRecord.Materials_and_Consumables_Justification__c}
                            </aura:if>
                            
                            
                        </div>
                        <br/><br/>
                        <div class="slds-progress__item_content slds-grid slds-grid_align-spread QuestionClass">4. Equipment purchase</div>
                        <div class="slds-progress__item_content slds-grid slds-grid_align-spread QuestionClass">Guidelines:</div>
                        <div class="slds-progress__item_content slds-grid slds-grid_align-spread">•	The estimated price of the equipment should cover all aspects including delivery, installation, maintenance, and training, where appropriate. Customs Tax is not covered by the India Alliance.</div>
                        <div class="slds-progress__item_content slds-grid slds-grid_align-spread">•	The India Alliance does not normally supplement support provided by other funding bodies. However, a contribution from the host institution, or other source, will normally be expected where the application includes a substantial equipment request.</div>
                        <div class="slds-progress__item_content slds-grid slds-grid_align-spread">•	Maintenance costs: It is expected that the equipment requested will be covered by the manufacturer’s warranty for the first year after it is purchased. A negotiated extended warranty is desirable. The India Alliance will consider funding reasonable maintenance costs for the remaining duration of the award.</div>
                        <div class="slds-progress__item_content slds-grid slds-grid_align-spread">•	The cost for desktop computers and laptops, if required, must be indicated under Equipment.</div>
                        <aura:if isTrue="{!v.defaultMode!='read'}"><div style="text-align:right;"><lightning:button variant="" label="Add Equipment" title="Add Equipment" value="{! v.form.budget.budgetRecord.Id}" name="v.showAddEQ" class="budgetIdeq" onclick="{! c.openModal }" /></div></aura:if>
                        <div class="slds-col slds-size_1-of-1 slds-large-size_12-of-12 tableScroll">
                            <table class="slds-table slds-table_cell-buffer slds-table_bordered">
                                <thead>
                                    <tr class="slds-line-height_reset">
                                        <th class="nowrap" scope="col">
                                            <div class=" " title="Type of equipment ">Type of <br/>equipment</div>
                                        </th>
                                        <th class="nowrap" scope="col">
                                            <div class=" " title="Number of items ">Number of <br/>items </div>
                                        </th>  
                                        <th class="nowrap" scope="col">
                                            <div class=" " title="Cost per item">Cost per item</div>
                                        </th>
                                        <th class="nowrap" scope="col">
                                            <div class=" " title="Cost of maintenance contract per year">Cost of maintenance <br/>contract <br/>per year</div>
                                        </th>
                                        <th class="nowrap" scope="col">
                                            <div class=" " title="Duration of maintenance contract (years)">Duration of <br/>maintenance contract <br/>(years)</div>
                                        </th>
                                        <th class="nowrap" scope="col">
                                            <div class=" " title="Contribution from other sources">Contribution from <br/>other sources</div>
                                        </th>
                                        <th class="nowrap" scope="col">
                                            <div class=" " title="Amount requested">Amount requested</div>
                                        </th>
                                        <aura:if isTrue="{!v.defaultMode!='read'}">
                                            <th class="nowrap" scope="col">
                                                <div class=" " title="Action">Action </div>
                                            </th>
                                        </aura:if>
                                    </tr>
                                </thead>
                                <tbody>
                                    <aura:iteration var="equ" items="{!v.form.budget.eqList }" indexVar="indx">
                                        <tr>
                                            <th class="" scope="col">
                                                <div class=" " title="{!equ.Type_of_Equipment__c}">{!equ.Type_of_Equipment__c}</div>
                                            </th>
                                            <th class="" scope="col">
                                                <div class=" " title="{!equ.Number_of_items__c}">{!equ.Number_of_items__c}</div>
                                            </th>
                                            <th class="" scope="col">
                                                <div class=" " title="{!equ.Cost_per_item__c}"><ui:outputCurrency value="{!equ.Cost_per_item__c}"/></div>
                                            </th>
                                            <th class="" scope="col">
                                                <div class=" " title="{!equ.Cost_of_maintenance_contract_per_year__c}">{!equ.Cost_of_maintenance_contract_per_year__c}</div>
                                            </th>
                                            <th class="" scope="col">
                                                <div class=" " title="{!equ.Duration_of_Maintenance__c}">{!equ.Duration_of_Maintenance__c}</div>
                                            </th>
                                            <th class="" scope="col">
                                                <div class=" " title="{!equ.Contribution_from_other_sources__c}">{!equ.Contribution_from_other_sources__c}</div>
                                            </th>
                                            <th class="" scope="col">
                                                <div class=" " title="{!equ.Total__c}"><ui:outputCurrency value="{!equ.Total__c}"/></div>
                                            </th>
                                            <aura:if isTrue="{!v.defaultMode!='read'}">
                                                <th class="nowrap" scope="col" >
                                                    <div class=" ">
                                                        <lightning:button variant="neutral" label="Edit" title="Edit" value="{! equ.Id}" name="v.showAddEQ" onclick="{! c.editRecord }"/>
                                                        <lightning:button variant="neutral" label="Remove" title="Remove" value="{!equ.Id}" onclick="{! c.removeRecord }" /></div>
                                                </th>
                                            </aura:if>
                                        </tr>
                                    </aura:iteration>
                                </tbody>
                                <thead>
                                    <tr>
                                        <th class="" scope="col" colspan="6">
                                            <div class=" " title="Total cost requested under equipment purchase head">Total cost requested under equipment purchase head</div>
                                        </th>
                                        <th class="" scope="col">
                                            <div class=" " title="{!v.form.budget.totaleqAmount  }"><ui:outputCurrency value="{!v.form.budget.totaleqAmount  }"/></div>
                                        </th>
                                        <aura:if isTrue="{!v.defaultMode!='read'}"><th class="" scope="col"></th></aura:if>
                                    </tr>
                                </thead>
                            </table>
                            <div class="slds-col slds-size_1-of-1 slds-large-size_12-of-12">
                                <div class="slds-progress__item_content slds-grid slds-grid_align-spread QuestionClass">Justification for equipment and equipment maintenance requested (Limit 500 words)</div>
                                <aura:if isTrue="{!v.defaultMode!='read'}">
                                    <lightning:textarea class="500" name="" label="" value="{!v.form.budget.budgetRecord.Equipment_Justification__c}" onchange="{!c.validateTextArea}"/>
                                </aura:if>
                                <aura:if isTrue="{!v.defaultMode=='read'}">
                                    {!v.form.budget.budgetRecord.Equipment_Justification__c}
                                </aura:if>
                                
                                
                            </div>
                        </div>
                        <br/>
                        <div class="slds-progress__item_content slds-grid slds-grid_align-spread QuestionClass">5. Access charges
                            <aura:if isTrue="{!v.defaultMode!='read'}"><div style="text-align:right;"><lightning:button variant="" label="Add Access Charges" value="{! v.form.budget.budgetRecord.Id}" name="v.showAddAC" class="budgetIdac" title="Add Access Charges" onclick="{! c.openModal }" /></div></aura:if></div>
                        <div class="slds-col slds-size_1-of-1 slds-large-size_12-of-12 tableScroll">
                            
                            <table class="slds-table slds-table_cell-buffer slds-table_bordered">
                                <thead>
                                    <tr class="slds-line-height_reset">
                                        <th class="nowrap" scope="col">
                                            <div class=" " title="Details of equipment/facility with location">Details of equipment/facility <br/>with location</div>
                                        </th>
                                        <th class="nowrap" scope="col">
                                            <div class=" " title="Specify access (units can be either defined as day or hour)">Specify access (units can be either <br/>defined as day or hour)</div>
                                        </th>  
                                        <th class="nowrap" scope="col">
                                            <div class=" " title="Place">Place</div>
                                        </th> 
                                        <th class="nowrap" scope="col">
                                            <div class=" " title="Number of units">Number of units</div>
                                        </th>
                                        <th class="nowrap" scope="col">
                                            <div class=" " title="Access charge per unit">Access charge per unit</div>
                                        </th>
                                        <th class="nowrap" scope="col">
                                            <div class=" " title="Total">Total</div>
                                        </th>
                                        <aura:if isTrue="{!v.defaultMode!='read'}">
                                            <th class="nowrap" scope="col">
                                                <div class=" " title="Action">Action </div>
                                            </th>
                                        </aura:if>
                                    </tr>
                                </thead>
                                <tbody>
                                    <aura:iteration var="acc" items="{!v.form.budget.accessList  }" indexVar="indx">
                                        <tr>
                                            <th class="" scope="col">
                                                <div class=" " title="{!acc.Name}">{!acc.Access_Charge_Name__c}</div>
                                            </th>
                                            <th class="" scope="col">
                                                <div class=" " title="{!acc.Specify_access__c}">{!acc.Specify_access__c}</div>
                                            </th>
                                            <th class="" scope="col">
                                                <div class=" " title="{!acc.Place__c}">{!acc.Place__c}</div>
                                            </th>
                                            <th class="" scope="col">
                                                <div class=" " title="{!acc.Number_of_Units__c}">{!acc.Number_of_Units__c}</div>
                                            </th>
                                            <th class="" scope="col">
                                                <div class=" " title="{!acc.Access_Charges_Per_Unit__c}"><ui:outputCurrency value="{!acc.Access_Charges_Per_Unit__c}"/></div>
                                            </th>
                                            <th class="" scope="col">
