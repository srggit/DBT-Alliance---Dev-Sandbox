                    <td style="border:1px solid black;width:40%;text-align:center;padding-left:10px;padding-right:10px">
                        <lightning:select variant="label-hidden" class="slt" label="" value="{!v.currentChecklist.No_link_with_Commercial_Organizations__c}">
                            <option value="">None</option>
                            <option value="Yes">Yes</option>
                            <option value="No">No</option>
                        </lightning:select>
                    </td>
                    <aura:set attribute="else">
                        <td style="border:1px solid black;width:40%;text-align:center">{!v.currentChecklist.No_link_with_Commercial_Organizations__c}</td>
                    </aura:set>
                </aura:if>
            </tr>
            
            <tr>
                <td style="border:1px solid black;width:20%;text-align:center;transform:rotate(270deg);height:50px"><b>
                    <aura:if isTrue="{!v.isTSG}">11</aura:if> <aura:if isTrue="{!v.isCRC}">12 </aura:if>
                    </b></td>
                <td style="border:1px solid black;width:40%;text-align:center">Restricted reviewers not included</td>
